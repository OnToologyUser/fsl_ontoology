#    Individuals
#################################################################

###  http://www.softlang.org/ontologies/pe#Ada
:Ada rdf:type owl:NamedIndividual ,
              :ProgrammingLanguage ,
              <http://www.softlang.org/ontologies/tbox#LanguageEntity> ;
     <http://www.softlang.org/ontologies/tbox#hasArea> <http://www.softlang.org/ontologies/ce#PLT> ,
                                                       <http://www.softlang.org/ontologies/ce#SE> ,
                                                       <http://www.softlang.org/ontologies/ce#SLE> ;
     <http://www.softlang.org/ontologies/tbox#hasSpace> <http://www.softlang.org/ontologies/ce#Programware> ;
     <http://www.softlang.org/ontologies/tbox#nativelySupports> <http://www.softlang.org/ontologies/ce#DataAbstraction> ,
                                                                <http://www.softlang.org/ontologies/ce#Exceptions> ,
                                                                <http://www.softlang.org/ontologies/ce#ImperativeParadigm> ,
                                                                <http://www.softlang.org/ontologies/ce#ProceduralAbstraction> ,
                                                                <http://www.softlang.org/ontologies/ce#SharedMemoryConcurrency> ,
                                                                <http://www.softlang.org/ontologies/ce#StaticTyping> ,
                                                                <http://www.softlang.org/ontologies/ce#StrongTyping> ,
                                                                <http://www.softlang.org/ontologies/ce#TaskParallelism> ;
     rdfs:comment "statically typed language with strong support for reliability and concurrency"@en ;
     rdfs:label "Ada"@en ;
     <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://dbpedia.org/resource/Ada_(programming_language)> ;
     <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Ada_(programming_language)> .


