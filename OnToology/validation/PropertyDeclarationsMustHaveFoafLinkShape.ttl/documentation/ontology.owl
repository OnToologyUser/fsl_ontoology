<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
     xml:base="http://www.w3.org/2002/07/owl"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:shacl="http://www.w3.org/ns/shacl#">
    <Ontology/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/ns/shacl#message -->


    <AnnotationProperty rdf:about="http://www.w3.org/ns/shacl#message"/>
    


    <!-- http://www.w3.org/ns/shacl#select -->


    <AnnotationProperty rdf:about="http://www.w3.org/ns/shacl#select"/>
    


    <!-- http://www.w3.org/ns/shacl#sparql -->


    <AnnotationProperty rdf:about="http://www.w3.org/ns/shacl#sparql"/>
    


    <!-- http://www.w3.org/ns/shacl#targetSubjectsOf -->


    <AnnotationProperty rdf:about="http://www.w3.org/ns/shacl#targetSubjectsOf"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/ns/shacl#NodeShape -->


    <Class rdf:about="http://www.w3.org/ns/shacl#NodeShape"/>
    


    <!-- http://www.w3.org/ns/shacl#SPARQLConstraint -->


    <Class rdf:about="http://www.w3.org/ns/shacl#SPARQLConstraint"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.softlang.org/ontologies/ve#PropertyDeclarationsMustHaveFoafLinkShape -->


    <NamedIndividual rdf:about="http://www.softlang.org/ontologies/ve#PropertyDeclarationsMustHaveFoafLinkShape">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#NodeShape"/>
        <shacl:sparql rdf:nodeID="genid2"/>
        <shacl:targetSubjectsOf rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#type"/>
    </NamedIndividual>
    <rdf:Description rdf:nodeID="genid2">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#SPARQLConstraint"/>
        <shacl:message>Property declaration is missing both foaf:page and foaf:isPrimaryTopicOf.</shacl:message>
        <shacl:select>
      SELECT $this
      WHERE {
        $this rdf:type ?t .
	FILTER(STRSTARTS(STR($this), &quot;http://www.softlang.org/ontologies/&quot;))
        FILTER (
          ?t IN (
            rdf:Property,
            owl:ObjectProperty,
            owl:DatatypeProperty,
            owl:AnnotationProperty,
            owl:OntologyProperty
          )
        )
        FILTER NOT EXISTS { $this foaf:page ?page . }
        FILTER NOT EXISTS { $this foaf:isPrimaryTopicOf ?topic . }
      }
    </shacl:select>
    </rdf:Description>
</rdf:RDF>



