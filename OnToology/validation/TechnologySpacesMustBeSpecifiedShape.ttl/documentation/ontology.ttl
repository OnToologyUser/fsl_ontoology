          <http://www.w3.org/ns/shacl#path> <http://www.softlang.org/ontologies/tbox#hasArtifact> .

_:genid3 <http://www.w3.org/ns/shacl#class> <http://www.softlang.org/ontologies/tbox#ToolEntity> ;
          <http://www.w3.org/ns/shacl#minCount> 1 ;
