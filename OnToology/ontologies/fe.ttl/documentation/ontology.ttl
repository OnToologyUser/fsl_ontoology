@prefix : <http://www.softlang.org/ontologies/fe#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.softlang.org/ontologies/fe#> .

<http://www.softlang.org/ontologies/fe> rdf:type owl:Ontology ;
                                         owl:imports <http://www.softlang.org/ontologies/tbox> ;
                                         <http://www.softlang.org/ontologies/tbox#commentingPolicy> "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         <http://www.softlang.org/ontologies/tbox#formattingPolicy> "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         <http://www.softlang.org/ontologies/tbox#linkingPolicy> "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         <http://www.softlang.org/ontologies/tbox#metamodelingPolicy> "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         rdfs:comment "Sub-ontology / ABox for the formal entities"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://www.softlang.org/ontologies/tbox#commentingPolicy
<http://www.softlang.org/ontologies/tbox#commentingPolicy> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#extends
<http://www.softlang.org/ontologies/tbox#extends> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#formattingPolicy
<http://www.softlang.org/ontologies/tbox#formattingPolicy> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#hasArea
<http://www.softlang.org/ontologies/tbox#hasArea> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#hasSpace
<http://www.softlang.org/ontologies/tbox#hasSpace> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#isSpecifiedBy
<http://www.softlang.org/ontologies/tbox#isSpecifiedBy> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#linkingPolicy
<http://www.softlang.org/ontologies/tbox#linkingPolicy> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#metamodelingPolicy
<http://www.softlang.org/ontologies/tbox#metamodelingPolicy> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#serves
<http://www.softlang.org/ontologies/tbox#serves> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#uses
<http://www.softlang.org/ontologies/tbox#uses> rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/isPrimaryTopicOf
<http://xmlns.com/foaf/0.1/isPrimaryTopicOf> rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/page
<http://xmlns.com/foaf/0.1/page> rdf:type owl:AnnotationProperty .


#################################################################
#    Classes
#################################################################

###  http://www.softlang.org/ontologies/fe#AbstractRewritingSystem
:AbstractRewritingSystem rdf:type owl:Class ;
                         rdfs:subClassOf :ModelOfComputation .


###  http://www.softlang.org/ontologies/fe#AnalyticGrammar
:AnalyticGrammar rdf:type owl:Class ;
                 rdfs:subClassOf :FormalGrammar .


###  http://www.softlang.org/ontologies/fe#ClassicalLambdaCalculus
:ClassicalLambdaCalculus rdf:type owl:Class ;
                         rdfs:subClassOf :LambdaCalculus .


###  http://www.softlang.org/ontologies/fe#ComputationalProblem
:ComputationalProblem rdf:type owl:Class ;
                      rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#FormalEntity> .


###  http://www.softlang.org/ontologies/fe#DataManagementApproach
:DataManagementApproach rdf:type owl:Class ;
                        rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#MethodologicalApproach> .


###  http://www.softlang.org/ontologies/fe#DataStructure
:DataStructure rdf:type owl:Class ;
               rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#FormalEntity> .


###  http://www.softlang.org/ontologies/fe#DescriptionLogic
:DescriptionLogic rdf:type owl:Class ;
                  rdfs:subClassOf :FormalSystem .


###  http://www.softlang.org/ontologies/fe#DomainTheory
:DomainTheory rdf:type owl:Class ;
              rdfs:subClassOf :Theory .


###  http://www.softlang.org/ontologies/fe#FormalGrammar
:FormalGrammar rdf:type owl:Class ;
               rdfs:subClassOf :FormalSystem .


###  http://www.softlang.org/ontologies/fe#FormalObject
:FormalObject rdf:type owl:Class ;
              rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#FormalEntity> .


###  http://www.softlang.org/ontologies/fe#FormalSemanticsApproach
:FormalSemanticsApproach rdf:type owl:Class ;
                         rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#MethodologicalApproach> .


###  http://www.softlang.org/ontologies/fe#FormalSystem
:FormalSystem rdf:type owl:Class ;
              rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#FormalEntity> .


###  http://www.softlang.org/ontologies/fe#GenerativeGrammar
:GenerativeGrammar rdf:type owl:Class ;
                   rdfs:subClassOf :FormalGrammar .


###  http://www.softlang.org/ontologies/fe#LambdaCalculus
:LambdaCalculus rdf:type owl:Class ;
                rdfs:subClassOf :FormalSystem .


###  http://www.softlang.org/ontologies/fe#LambdaCube
:LambdaCube rdf:type owl:Class ;
            rdfs:subClassOf :LambdaCalculus .


###  http://www.softlang.org/ontologies/fe#MathematicalStructure
:MathematicalStructure rdf:type owl:Class ;
                       rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#FormalEntity> .


###  http://www.softlang.org/ontologies/fe#MetaprogrammingApproach
:MetaprogrammingApproach rdf:type owl:Class ;
                         rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#MethodologicalApproach> .


###  http://www.softlang.org/ontologies/fe#ModelOfComputation
:ModelOfComputation rdf:type owl:Class ;
                    rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#FormalEntity> .


###  http://www.softlang.org/ontologies/fe#ProcessCalculus
:ProcessCalculus rdf:type owl:Class ;
                 rdfs:subClassOf :FormalSystem .


###  http://www.softlang.org/ontologies/fe#ProgramLogic
:ProgramLogic rdf:type owl:Class ;
              rdfs:subClassOf :FormalSystem .


###  http://www.softlang.org/ontologies/fe#SoftwareDesignApproach
:SoftwareDesignApproach rdf:type owl:Class ;
                        rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#MethodologicalApproach> .


###  http://www.softlang.org/ontologies/fe#SyntaxDefinitionApproach
:SyntaxDefinitionApproach rdf:type owl:Class ;
                          rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#MethodologicalApproach> .


###  http://www.softlang.org/ontologies/fe#Theory
:Theory rdf:type owl:Class ;
        rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#FormalEntity> .


###  http://www.softlang.org/ontologies/fe#TransitionSystem
:TransitionSystem rdf:type owl:Class ;
                  rdfs:subClassOf :ModelOfComputation .


###  http://www.softlang.org/ontologies/fe#TypeTheory
:TypeTheory rdf:type owl:Class ;
            rdfs:subClassOf :Theory .


###  http://www.softlang.org/ontologies/tbox#FormalEntity
<http://www.softlang.org/ontologies/tbox#FormalEntity> rdf:type owl:Class .


###  http://www.softlang.org/ontologies/tbox#MethodologicalApproach
<http://www.softlang.org/ontologies/tbox#MethodologicalApproach> rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://www.softlang.org/ontologies/fe#ALC
:ALC rdf:type owl:NamedIndividual ,
              :DescriptionLogic ,
              <http://www.softlang.org/ontologies/tbox#FormalEntity> ;
     <http://www.softlang.org/ontologies/tbox#hasArea> <http://www.softlang.org/ontologies/ce#KR> ,
                                                       <http://www.softlang.org/ontologies/ce#TCS> ;
     <http://www.softlang.org/ontologies/tbox#hasSpace> <http://www.softlang.org/ontologies/ce#Ontoware> ;
     rdfs:comment "basic attributional description logic with complement"@en ;
     rdfs:label "ALC"@en ;
     <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/Description_logic> .


###  http://www.softlang.org/ontologies/fe#AbstractRewritingSystem
:AbstractRewritingSystem rdf:type owl:NamedIndividual ,
                                  <http://www.softlang.org/ontologies/tbox#FormalEntity> .


###  http://www.softlang.org/ontologies/fe#AbstractSyntaxDefinitionApproach
:AbstractSyntaxDefinitionApproach rdf:type owl:NamedIndividual ,
                                           :SyntaxDefinitionApproach ,
                                           <http://www.softlang.org/ontologies/tbox#FormalEntity> ;
                                  <http://www.softlang.org/ontologies/tbox#hasArea> <http://www.softlang.org/ontologies/ce#CC> ,
                                                                                    <http://www.softlang.org/ontologies/ce#MDE> ,
                                                                                    <http://www.softlang.org/ontologies/ce#PLT> ,
                                                                                    <http://www.softlang.org/ontologies/ce#SLE> ;
                                  <http://www.softlang.org/ontologies/tbox#hasSpace> <http://www.softlang.org/ontologies/ce#Grammarware> ,
                                                                                     <http://www.softlang.org/ontologies/ce#JSONware> ,
                                                                                     <http://www.softlang.org/ontologies/ce#Modelware> ,
                                                                                     <http://www.softlang.org/ontologies/ce#XMLware> ;
                                  rdfs:comment "syntax-definition approach concerned with the structural representation of language constructs independently of concrete notation details"@en ;
                                  rdfs:label "Abstract syntax definition approach"@en ;
                                  <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/Abstract_syntax> .


###  http://www.softlang.org/ontologies/fe#AnalyticGrammar
:AnalyticGrammar rdf:type owl:NamedIndividual ,
                          <http://www.softlang.org/ontologies/tbox#FormalEntity> .


###  http://www.softlang.org/ontologies/fe#AttributeGrammar
:AttributeGrammar rdf:type owl:NamedIndividual ,
                           :FormalGrammar ,
                           <http://www.softlang.org/ontologies/tbox#FormalEntity> ;
                  <http://www.softlang.org/ontologies/tbox#extends> :ContextFreeGrammar ;
                  <http://www.softlang.org/ontologies/tbox#hasArea> <http://www.softlang.org/ontologies/ce#CC> ,
                                                                    <http://www.softlang.org/ontologies/ce#PLT> ,
                                                                    <http://www.softlang.org/ontologies/ce#SLE> ;
                  <http://www.softlang.org/ontologies/tbox#hasSpace> <http://www.softlang.org/ontologies/ce#Grammarware> ;
                  <http://www.softlang.org/ontologies/tbox#serves> :SyntaxDirectedTranslation ;
                  <http://www.softlang.org/ontologies/tbox#uses> :ContextFreeGrammar ;
                  rdfs:comment "formal grammar with attributes and semantic rules"@en ;
                  rdfs:label "Attribute grammar"@en ;
                  <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/Attribute_grammar> .


###  http://www.softlang.org/ontologies/fe#AxiomaticSemantics
:AxiomaticSemantics rdf:type owl:NamedIndividual ,
                             :FormalSemanticsApproach ,
                             <http://www.softlang.org/ontologies/tbox#FormalEntity> ;
                    <http://www.softlang.org/ontologies/tbox#hasArea> <http://www.softlang.org/ontologies/ce#FM> ,
                                                                      <http://www.softlang.org/ontologies/ce#PLT> ;
                    <http://www.softlang.org/ontologies/tbox#hasSpace> <http://www.softlang.org/ontologies/ce#Programware> ;
                    <http://www.softlang.org/ontologies/tbox#uses> :AbstractSyntaxDefinitionApproach ,
                                                                   :ProgramLogic ;
                    rdfs:comment "formal-semantics approach based on axioms and logical proof principles"@en ;
                    rdfs:label "Axiomatic semantics"@en ;
                    <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/Axiomatic_semantics> .


###  http://www.softlang.org/ontologies/fe#CalculusOfCommunicatingSystems
:CalculusOfCommunicatingSystems rdf:type owl:NamedIndividual ,
                                         :ProcessCalculus ,
                                         <http://www.softlang.org/ontologies/tbox#FormalEntity> ;
                                <http://www.softlang.org/ontologies/tbox#hasArea> <http://www.softlang.org/ontologies/ce#PLT> ,
                                                                                  <http://www.softlang.org/ontologies/ce#TCS> ;
                                <http://www.softlang.org/ontologies/tbox#hasSpace> <http://www.softlang.org/ontologies/ce#Programware> ;
                                <http://www.softlang.org/ontologies/tbox#isSpecifiedBy> :OperationalSemantics ;
                                rdfs:comment "calculus for communicating concurrent systems"@en ;
                                rdfs:label "Calculus of communicating systems"@en ;
                                <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/Calculus_of_communicating_systems> .


###  http://www.softlang.org/ontologies/fe#CategoryTheory
:CategoryTheory rdf:type owl:NamedIndividual ,
                         :Theory ,
                         <http://www.softlang.org/ontologies/tbox#FormalEntity> ;
                <http://www.softlang.org/ontologies/tbox#hasArea> <http://www.softlang.org/ontologies/ce#FM> ,
                                                                  <http://www.softlang.org/ontologies/ce#MDE> ,
                                                                  <http://www.softlang.org/ontologies/ce#TCS> ;
                <http://www.softlang.org/ontologies/tbox#hasSpace> <http://www.softlang.org/ontologies/ce#Modelware> ;
                rdfs:comment "mathematical theory of objects and morphisms used widely in abstract modeling and semantics"@en ;
                rdfs:label "Category theory"@en ;
                <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/Category_theory> .


###  http://www.softlang.org/ontologies/fe#ClassicalLambdaCalculus
:ClassicalLambdaCalculus rdf:type owl:NamedIndividual ,
                                  <http://www.softlang.org/ontologies/tbox#FormalEntity> .


###  http://www.softlang.org/ontologies/fe#CommunicatingSequentialProcesses
:CommunicatingSequentialProcesses rdf:type owl:NamedIndividual ,
                                           :ProcessCalculus ,
                                           <http://www.softlang.org/ontologies/tbox#FormalEntity> ;
                                  <http://www.softlang.org/ontologies/tbox#hasArea> <http://www.softlang.org/ontologies/ce#FM> ,
                                                                                    <http://www.softlang.org/ontologies/ce#PLT> ,
                                                                                    <http://www.softlang.org/ontologies/ce#TCS> ;
                                  <http://www.softlang.org/ontologies/tbox#hasSpace> <http://www.softlang.org/ontologies/ce#Programware> ;
                                  <http://www.softlang.org/ontologies/tbox#isSpecifiedBy> :OperationalSemantics ;
                                  rdfs:comment "process algebra for communication"@en ;
                                  rdfs:label "Communicating sequential processes"@en ;
                                  <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/Communicating_sequential_processes> .


###  http://www.softlang.org/ontologies/fe#ComputationalProblem
:ComputationalProblem rdf:type owl:NamedIndividual ,
                               <http://www.softlang.org/ontologies/tbox#FormalEntity> .


###  http://www.softlang.org/ontologies/fe#ConcreteSyntaxDefinitionApproach
:ConcreteSyntaxDefinitionApproach rdf:type owl:NamedIndividual ,
                                           :SyntaxDefinitionApproach ,
                                           <http://www.softlang.org/ontologies/tbox#FormalEntity> ;
                                  <http://www.softlang.org/ontologies/tbox#hasArea> <http://www.softlang.org/ontologies/ce#CC> ,
                                                                                    <http://www.softlang.org/ontologies/ce#MDE> ,
                                                                                    <http://www.softlang.org/ontologies/ce#SLE> ;
                                  <http://www.softlang.org/ontologies/tbox#hasSpace> <http://www.softlang.org/ontologies/ce#Grammarware> ,
                                                                                     <http://www.softlang.org/ontologies/ce#Modelware> ;
                                  rdfs:comment "syntax-definition approach concerned with the explicit surface representation of language constructs, including notation, delimiters, and other syntactically relevant details"@en ;
                                  rdfs:label "Concrete syntax definition approach"@en .


###  http://www.softlang.org/ontologies/fe#ConstraintSatisfactionProblem
:ConstraintSatisfactionProblem rdf:type owl:NamedIndividual ,
                                        :ComputationalProblem ,
                                        <http://www.softlang.org/ontologies/tbox#FormalEntity> ;
                               <http://www.softlang.org/ontologies/tbox#hasArea> <http://www.softlang.org/ontologies/ce#FM> ,
                                                                                 <http://www.softlang.org/ontologies/ce#SE> ,
                                                                                 <http://www.softlang.org/ontologies/ce#TCS> ;
                               rdfs:comment "computational problem of assigning values so that all specified constraints are satisfied"@en ,
                                            "computational problem of assigning values subject to constraints"@en ;
                               rdfs:label "Constraint satisfaction problem"@en ;
                               <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/Constraint_satisfaction_problem> .


###  http://www.softlang.org/ontologies/fe#ContextFreeGrammar
:ContextFreeGrammar rdf:type owl:NamedIndividual ,
                             :GenerativeGrammar ,
                             <http://www.softlang.org/ontologies/tbox#FormalEntity> ;
                    <http://www.softlang.org/ontologies/tbox#hasArea> <http://www.softlang.org/ontologies/ce#CC> ,
                                                                      <http://www.softlang.org/ontologies/ce#SLE> ,
                                                                      <http://www.softlang.org/ontologies/ce#TCS> ;
                    <http://www.softlang.org/ontologies/tbox#hasSpace> <http://www.softlang.org/ontologies/ce#Grammarware> ;
                    <http://www.softlang.org/ontologies/tbox#serves> :ConcreteSyntaxDefinitionApproach ;
                    rdfs:comment "grammar with context-free productions"@en ;
                    rdfs:label "Context-free grammar"@en ;
                    <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/Context-free_grammar> .


###  http://www.softlang.org/ontologies/fe#DataManagementApproach
:DataManagementApproach rdf:type owl:NamedIndividual ,
                                 <http://www.softlang.org/ontologies/tbox#FormalEntity> .


###  http://www.softlang.org/ontologies/fe#DataStructure
:DataStructure rdf:type owl:NamedIndividual ,
                        <http://www.softlang.org/ontologies/tbox#FormalEntity> .


###  http://www.softlang.org/ontologies/fe#DataValidation
:DataValidation rdf:type owl:NamedIndividual ,
                         :DataManagementApproach ,
                         <http://www.softlang.org/ontologies/tbox#FormalEntity> ;
                <http://www.softlang.org/ontologies/tbox#hasArea> <http://www.softlang.org/ontologies/ce#SE> ,
                                                                  <http://www.softlang.org/ontologies/ce#SLE> ;
                <http://www.softlang.org/ontologies/tbox#hasSpace> <http://www.softlang.org/ontologies/ce#JSONware> ,
                                                                   <http://www.softlang.org/ontologies/ce#Ontoware> ,
                                                                   <http://www.softlang.org/ontologies/ce#SQLware> ,
                                                                   <http://www.softlang.org/ontologies/ce#XMLware> ;
                rdfs:comment "data-management methodology concerned with checking data quality and conformance to constraints"@en ,
                             "data-management methodology concerned with ensuring that data conforms to structural and semantic expectations"@en ;
                rdfs:label "Data validation"@en ;
                <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/Data_validation> .


###  http://www.softlang.org/ontologies/fe#DenotationalSemantics
:DenotationalSemantics rdf:type owl:NamedIndividual ,
                                :FormalSemanticsApproach ,
                                <http://www.softlang.org/ontologies/tbox#FormalEntity> ;
                       <http://www.softlang.org/ontologies/tbox#hasArea> <http://www.softlang.org/ontologies/ce#PLT> ,
                                                                         <http://www.softlang.org/ontologies/ce#SLE> ;
                       <http://www.softlang.org/ontologies/tbox#hasSpace> <http://www.softlang.org/ontologies/ce#Programware> ;
                       <http://www.softlang.org/ontologies/tbox#serves> :MetaprogrammingApproach ,
                                                                        :ProgramTransformation ;
                       <http://www.softlang.org/ontologies/tbox#uses> :AbstractSyntaxDefinitionApproach ,
                                                                      :DomainTheory ,
                                                                      :LambdaCalculus ;
                       rdfs:comment "formal-semantics approach based on mathematical denotations"@en ;
                       rdfs:label "Denotational semantics"@en ;
                       <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/Denotational_semantics> .


###  http://www.softlang.org/ontologies/fe#DependencyGrammar
:DependencyGrammar rdf:type owl:NamedIndividual ,
                            :FormalGrammar ,
                            <http://www.softlang.org/ontologies/tbox#FormalEntity> ;
                   <http://www.softlang.org/ontologies/tbox#hasArea> <http://www.softlang.org/ontologies/ce#CL> ,
                                                                     <http://www.softlang.org/ontologies/ce#NLP> ,
                                                                     <http://www.softlang.org/ontologies/ce#TCS> ;
                   <http://www.softlang.org/ontologies/tbox#hasSpace> <http://www.softlang.org/ontologies/ce#Grammarware> ;
                   rdfs:comment "grammar based on dependency relations"@en ;
                   rdfs:label "Dependency grammar"@en ;
                   <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/Dependency_grammar> .


###  http://www.softlang.org/ontologies/fe#DependencyGraph
:DependencyGraph rdf:type owl:NamedIndividual ,
                          :DataStructure ,
                          <http://www.softlang.org/ontologies/tbox#FormalEntity> ;
                 <http://www.softlang.org/ontologies/tbox#hasArea> <http://www.softlang.org/ontologies/ce#SE> ,
                                                                   <http://www.softlang.org/ontologies/ce#SLE> ;
                 <http://www.softlang.org/ontologies/tbox#hasSpace> <http://www.softlang.org/ontologies/ce#Graphware> ;
                 rdfs:comment "data structure representing dependency relations among entities"@en ,
                              "data-structure notion of a graph used to represent dependency relationships"@en ;
                 rdfs:label "Dependency graph"@en ;
                 <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/Dependency_graph> .


###  http://www.softlang.org/ontologies/fe#DescriptionLogic
:DescriptionLogic rdf:type owl:NamedIndividual ,
                           <http://www.softlang.org/ontologies/tbox#FormalEntity> .


###  http://www.softlang.org/ontologies/fe#DesignByContract
:DesignByContract rdf:type owl:NamedIndividual ,
                           :SoftwareDesignApproach ,
                           <http://www.softlang.org/ontologies/tbox#FormalEntity> ;
                  <http://www.softlang.org/ontologies/tbox#hasArea> <http://www.softlang.org/ontologies/ce#FM> ,
                                                                    <http://www.softlang.org/ontologies/ce#SE> ,
                                                                    <http://www.softlang.org/ontologies/ce#SLE> ;
                  <http://www.softlang.org/ontologies/tbox#hasSpace> <http://www.softlang.org/ontologies/ce#APIware> ;
                  rdfs:comment "software-design methodology based on explicit obligations, guarantees, and contracts"@en ,
                               "software-design methodology based on formally specified obligations and guarantees"@en ;
                  rdfs:label "Design by contract"@en ;
                  <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/Design_by_contract> .


###  http://www.softlang.org/ontologies/fe#DomainTheory
:DomainTheory rdf:type owl:NamedIndividual ,
                       <http://www.softlang.org/ontologies/tbox#FormalEntity> .


###  http://www.softlang.org/ontologies/fe#ELPlusPlus
:ELPlusPlus rdf:type owl:NamedIndividual ,
                     :DescriptionLogic ,
                     <http://www.softlang.org/ontologies/tbox#FormalEntity> ;
            <http://www.softlang.org/ontologies/tbox#hasArea> <http://www.softlang.org/ontologies/ce#KR> ,
                                                              <http://www.softlang.org/ontologies/ce#TCS> ;
            <http://www.softlang.org/ontologies/tbox#hasSpace> <http://www.softlang.org/ontologies/ce#Ontoware> ;
            rdfs:comment "lightweight description logic underlying the OWL 2 EL profile"@en ;
            rdfs:label "EL++"@en ;
            <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/EL%2B%2B> .


###  http://www.softlang.org/ontologies/fe#FirstOrderLogic
