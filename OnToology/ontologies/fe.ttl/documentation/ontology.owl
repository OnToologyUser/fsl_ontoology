    <!-- http://www.softlang.org/ontologies/fe#ALC -->


    <owl:NamedIndividual rdf:about="http://www.softlang.org/ontologies/fe#ALC">
        <rdf:type rdf:resource="http://www.softlang.org/ontologies/fe#DescriptionLogic"/>
        <rdf:type rdf:resource="http://www.softlang.org/ontologies/tbox#FormalEntity"/>
        <tbox:hasArea rdf:resource="http://www.softlang.org/ontologies/ce#KR"/>
        <tbox:hasArea rdf:resource="http://www.softlang.org/ontologies/ce#TCS"/>
        <tbox:hasSpace rdf:resource="http://www.softlang.org/ontologies/ce#Ontoware"/>
        <rdfs:comment xml:lang="en">basic attributional description logic with complement</rdfs:comment>
        <rdfs:label xml:lang="en">ALC</rdfs:label>
        <foaf:isPrimaryTopicOf rdf:resource="https://en.wikipedia.org/wiki/Description_logic"/>
    </owl:NamedIndividual>
    


    <!-- http://www.softlang.org/ontologies/fe#AbstractRewritingSystem -->


    <owl:NamedIndividual rdf:about="http://www.softlang.org/ontologies/fe#AbstractRewritingSystem">
        <rdf:type rdf:resource="http://www.softlang.org/ontologies/tbox#FormalEntity"/>
    </owl:NamedIndividual>
    


    <!-- http://www.softlang.org/ontologies/fe#AbstractSyntaxDefinitionApproach -->


    <owl:NamedIndividual rdf:about="http://www.softlang.org/ontologies/fe#AbstractSyntaxDefinitionApproach">
        <rdf:type rdf:resource="http://www.softlang.org/ontologies/fe#SyntaxDefinitionApproach"/>
        <rdf:type rdf:resource="http://www.softlang.org/ontologies/tbox#FormalEntity"/>
        <tbox:hasArea rdf:resource="http://www.softlang.org/ontologies/ce#CC"/>
        <tbox:hasArea rdf:resource="http://www.softlang.org/ontologies/ce#MDE"/>
        <tbox:hasArea rdf:resource="http://www.softlang.org/ontologies/ce#PLT"/>
        <tbox:hasArea rdf:resource="http://www.softlang.org/ontologies/ce#SLE"/>
        <tbox:hasSpace rdf:resource="http://www.softlang.org/ontologies/ce#Grammarware"/>
        <tbox:hasSpace rdf:resource="http://www.softlang.org/ontologies/ce#JSONware"/>
        <tbox:hasSpace rdf:resource="http://www.softlang.org/ontologies/ce#Modelware"/>
        <tbox:hasSpace rdf:resource="http://www.softlang.org/ontologies/ce#XMLware"/>
        <rdfs:comment xml:lang="en">syntax-definition approach concerned with the structural representation of language constructs independently of concrete notation details</rdfs:comment>
        <rdfs:label xml:lang="en">Abstract syntax definition approach</rdfs:label>
        <foaf:isPrimaryTopicOf rdf:resource="https://en.wikipedia.org/wiki/Abstract_syntax"/>
    </owl:NamedIndividual>
    


    <!-- http://www.softlang.org/ontologies/fe#AnalyticGrammar -->


    <owl:NamedIndividual rdf:about="http://www.softlang.org/ontologies/fe#AnalyticGrammar">
