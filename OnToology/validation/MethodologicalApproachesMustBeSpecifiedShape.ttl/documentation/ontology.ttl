###  http://www.softlang.org/ontologies/ve#MethodologicalApproachesMustBeSpecifiedShape
<http://www.softlang.org/ontologies/ve#MethodologicalApproachesMustBeSpecifiedShape> rdf:type owl:NamedIndividual ,
                                                                                              <http://www.w3.org/ns/shacl#NodeShape> ;
                                                                                     rdfs:comment "TODO" ;
                                                                                     <http://www.w3.org/ns/shacl#property> _:genid2 ;
                                                                                     <http://www.w3.org/ns/shacl#target> <http://www.softlang.org/ontologies/ve#MethodologicalApproachesMustBeSpecifiedTarget> .

_:genid2 <http://www.w3.org/ns/shacl#path> [ <http://www.w3.org/ns/shacl#alternativePath> [ ]
          ] ;
<http://www.w3.org/ns/shacl#qualifiedMinCount> 1 ;
<http://www.w3.org/ns/shacl#qualifiedValueShape> [ <http://www.w3.org/ns/shacl#class> <http://www.softlang.org/ontologies/tbox#Entity>
                                                 ] .


###  http://www.softlang.org/ontologies/ve#MethodologicalApproachesMustBeSpecifiedTarget
<http://www.softlang.org/ontologies/ve#MethodologicalApproachesMustBeSpecifiedTarget> rdf:type owl:NamedIndividual ,
                                                                                               <http://www.w3.org/ns/shacl#SPARQLTarget> ;
                                                                                      rdfs:comment "TODO" ;
                                                                                      <http://www.w3.org/ns/shacl#select> """
    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
    PREFIX fe:  <http://www.softlang.org/ontologies/fe#>

    SELECT ?this
    WHERE {
      ?this rdf:type fe:MethodologicalApproach .
      FILTER(?this NOT IN (
          fe:AbstractSyntaxDefinitionApproach,
      	  fe:AxiomaticSemantics,
          fe:DataValidation,
          fe:DesignByContract,
          fe:ModelTransformation,
          fe:RelationalModel
        )
      )
    }
  """ .


