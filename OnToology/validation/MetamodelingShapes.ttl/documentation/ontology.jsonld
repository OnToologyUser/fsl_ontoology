[ {
  "@id" : "_:genid1",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ]
}, {
  "@id" : "_:genid2",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/ns/shacl#SPARQLConstraint"
  } ],
  "http://www.w3.org/ns/shacl#message" : [ {
    "@value" : "Anything below the immediate subclasses of tbox:ArtifactEntity must be of type tbox:ArtifactEntity."
  } ],
  "http://www.w3.org/ns/shacl#select" : [ {
    "@value" : "\n      PREFIX tbox: <http://www.softlang.org/ontologies/tbox#>\n      PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\n      PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\n\n      SELECT $this\n      WHERE {\n        FILTER($this != owl:Nothing)\n      \t$this rdfs:subClassOf ?super .\n      \t?super rdfs:subClassOf+ tbox:ArtifactEntity .\n        FILTER NOT EXISTS {\n          $this rdf:type tbox:ArtifactEntity .\n        }\n      }\n    "
  } ]
}, {
  "@id" : "_:genid3",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/ns/shacl#SPARQLConstraint"
  } ],
  "http://www.w3.org/ns/shacl#message" : [ {
    "@value" : "Anything below the immediate subclasses of tbox:ConceptualEntity must be of type tbox:ConceptualEntity."
  } ],
  "http://www.w3.org/ns/shacl#select" : [ {
    "@value" : "\n      PREFIX tbox: <http://www.softlang.org/ontologies/tbox#>\n      PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\n      PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\n\n      SELECT $this\n      WHERE {\n        FILTER($this != owl:Nothing)\n      \t$this rdfs:subClassOf ?super .\n        ?super rdfs:subClassOf+ tbox:ConceptualEntity .\n        FILTER NOT EXISTS {\n          $this rdf:type tbox:ConceptualEntity .\n        }\n      }\n    "
  } ]
}, {
  "@id" : "_:genid4",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/ns/shacl#SPARQLConstraint"
  } ],
  "http://www.w3.org/ns/shacl#message" : [ {
    "@value" : "Anything below the immediate subclasses of tbox:FoundationalEntity must be of type tbox:FoundationalEntity."
  } ],
  "http://www.w3.org/ns/shacl#select" : [ {
    "@value" : "\n      PREFIX tbox: <http://www.softlang.org/ontologies/tbox#>\n      PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\n      PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\n\n      SELECT $this\n      WHERE {\n        FILTER($this != owl:Nothing)\n      \t$this rdfs:subClassOf ?super .\n        ?super rdfs:subClassOf+ tbox:FoundationalEntity .\n        FILTER NOT EXISTS {\n          $this rdf:type tbox:FoundationalEntity .\n        }\n      }\n    "
  } ]
