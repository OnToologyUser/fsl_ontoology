    <!-- http://www.softlang.org/ontologies/te#ANTLR -->


    <owl:NamedIndividual rdf:about="http://www.softlang.org/ontologies/te#ANTLR">
        <rdf:type rdf:resource="http://www.softlang.org/ontologies/tbox#ToolEntity"/>
        <rdf:type rdf:resource="http://www.softlang.org/ontologies/te#ParserGenerator"/>
        <rdfs:comment xml:lang="en">parser generator based on grammar notation with semantic and syntactic processing support</rdfs:comment>
        <rdfs:label xml:lang="en">ANTLR</rdfs:label>
        <foaf:isPrimaryTopicOf rdf:resource="https://en.wikipedia.org/wiki/ANTLR"/>
    </owl:NamedIndividual>
    


