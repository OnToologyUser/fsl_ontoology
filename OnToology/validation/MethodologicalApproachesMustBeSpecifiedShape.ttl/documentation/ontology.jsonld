  "http://www.w3.org/ns/shacl#target" : [ {
    "@id" : "http://www.softlang.org/ontologies/ve#MethodologicalApproachesMustBeSpecifiedTarget"
  } ]
}, {
  "@id" : "http://www.softlang.org/ontologies/ve#MethodologicalApproachesMustBeSpecifiedTarget",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/ns/shacl#SPARQLTarget"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "TODO"
  } ],
  "http://www.w3.org/ns/shacl#select" : [ {
    "@value" : "\n    PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\n    PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\n    PREFIX fe:  <http://www.softlang.org/ontologies/fe#>\n\n    SELECT ?this\n    WHERE {\n      ?this rdf:type fe:MethodologicalApproach .\n      FILTER(?this NOT IN (\n          fe:AbstractSyntaxDefinitionApproach,\n      \t  fe:AxiomaticSemantics,\n          fe:DataValidation,\n          fe:DesignByContract,\n          fe:ModelTransformation,\n          fe:RelationalModel\n        )\n      )\n    }\n  "
  } ]
}, {
