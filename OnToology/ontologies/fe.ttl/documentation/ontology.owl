        <tbox:uses rdf:resource="http://www.softlang.org/ontologies/fe#ContextFreeGrammar"/>
        <rdfs:comment xml:lang="en">formal grammar with attributes and semantic rules</rdfs:comment>
        <rdfs:label xml:lang="en">Attribute grammar</rdfs:label>
        <foaf:isPrimaryTopicOf rdf:resource="https://en.wikipedia.org/wiki/Attribute_grammar"/>
    </owl:NamedIndividual>
    


    <!-- http://www.softlang.org/ontologies/fe#AxiomaticSemantics -->


    <owl:NamedIndividual rdf:about="http://www.softlang.org/ontologies/fe#AxiomaticSemantics">
        <rdf:type rdf:resource="http://www.softlang.org/ontologies/fe#FormalSemanticsApproach"/>
        <rdf:type rdf:resource="http://www.softlang.org/ontologies/tbox#FormalEntity"/>
        <tbox:hasArea rdf:resource="http://www.softlang.org/ontologies/ce#FM"/>
        <tbox:hasArea rdf:resource="http://www.softlang.org/ontologies/ce#PLT"/>
        <tbox:hasSpace rdf:resource="http://www.softlang.org/ontologies/ce#Programware"/>
        <tbox:uses rdf:resource="http://www.softlang.org/ontologies/fe#AbstractSyntaxDefinitionApproach"/>
        <tbox:uses rdf:resource="http://www.softlang.org/ontologies/fe#ProgramLogic"/>
        <rdfs:comment xml:lang="en">formal-semantics approach based on axioms and logical proof principles</rdfs:comment>
        <rdfs:label xml:lang="en">Axiomatic semantics</rdfs:label>
        <foaf:isPrimaryTopicOf rdf:resource="https://en.wikipedia.org/wiki/Axiomatic_semantics"/>
    </owl:NamedIndividual>
    


