    <!-- http://www.softlang.org/ontologies/ve#MetamodellingArtifactEntityShape -->


    <NamedIndividual rdf:about="http://www.softlang.org/ontologies/ve#MetamodellingArtifactEntityShape">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#NodeShape"/>
        <shacl:sparql rdf:nodeID="genid2"/>
        <shacl:targetSubjectsOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
    </NamedIndividual>
    <rdf:Description rdf:nodeID="genid2">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#SPARQLConstraint"/>
        <shacl:message>Anything below the immediate subclasses of tbox:ArtifactEntity must be of type tbox:ArtifactEntity.</shacl:message>
        <shacl:select>
      PREFIX tbox: &lt;http://www.softlang.org/ontologies/tbox#&gt;
      PREFIX rdf:  &lt;http://www.w3.org/1999/02/22-rdf-syntax-ns#&gt;
      PREFIX rdfs: &lt;http://www.w3.org/2000/01/rdf-schema#&gt;

      SELECT $this
      WHERE {
        FILTER($this != owl:Nothing)
      	$this rdfs:subClassOf ?super .
      	?super rdfs:subClassOf+ tbox:ArtifactEntity .
        FILTER NOT EXISTS {
          $this rdf:type tbox:ArtifactEntity .
        }
      }
    </shacl:select>
    </rdf:Description>
    


