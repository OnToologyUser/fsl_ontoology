###  http://www.softlang.org/ontologies/ve#MetamodellingArtifactEntityShape
<http://www.softlang.org/ontologies/ve#MetamodellingArtifactEntityShape> rdf:type owl:NamedIndividual ,
                                                                                  <http://www.w3.org/ns/shacl#NodeShape> ;
                                                                         <http://www.w3.org/ns/shacl#sparql> _:genid2 ;
                                                                         <http://www.w3.org/ns/shacl#targetSubjectsOf> rdfs:subClassOf .

_:genid2 rdf:type <http://www.w3.org/ns/shacl#SPARQLConstraint> ;
          <http://www.w3.org/ns/shacl#message> "Anything below the immediate subclasses of tbox:ArtifactEntity must be of type tbox:ArtifactEntity." ;
          <http://www.w3.org/ns/shacl#select> """
      PREFIX tbox: <http://www.softlang.org/ontologies/tbox#>
      PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
      PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

      SELECT $this
      WHERE {
        FILTER($this != owl:Nothing)
      	$this rdfs:subClassOf ?super .
      	?super rdfs:subClassOf+ tbox:ArtifactEntity .
        FILTER NOT EXISTS {
          $this rdf:type tbox:ArtifactEntity .
        }
      }
    """ .


