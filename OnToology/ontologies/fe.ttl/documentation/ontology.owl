        <tbox:hasArea rdf:resource="http://www.softlang.org/ontologies/ce#PLT"/>
        <tbox:hasArea rdf:resource="http://www.softlang.org/ontologies/ce#TCS"/>
        <tbox:hasSpace rdf:resource="http://www.softlang.org/ontologies/ce#Programware"/>
        <tbox:isSpecifiedBy rdf:resource="http://www.softlang.org/ontologies/fe#OperationalSemantics"/>
        <rdfs:comment xml:lang="en">calculus for communicating concurrent systems</rdfs:comment>
        <rdfs:label xml:lang="en">Calculus of communicating systems</rdfs:label>
        <foaf:isPrimaryTopicOf rdf:resource="https://en.wikipedia.org/wiki/Calculus_of_communicating_systems"/>
    </owl:NamedIndividual>
    


    <!-- http://www.softlang.org/ontologies/fe#CategoryTheory -->


    <owl:NamedIndividual rdf:about="http://www.softlang.org/ontologies/fe#CategoryTheory">
        <rdf:type rdf:resource="http://www.softlang.org/ontologies/fe#Theory"/>
