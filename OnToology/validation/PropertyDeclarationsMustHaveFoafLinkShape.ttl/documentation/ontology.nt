_:genid2 <http://www.w3.org/ns/shacl#select> "\n      SELECT $this\n      WHERE {\n        $this rdf:type ?t .\n\tFILTER(STRSTARTS(STR($this), \"http://www.softlang.org/ontologies/\"))\n        FILTER (\n          ?t IN (\n            rdf:Property,\n            owl:ObjectProperty,\n            owl:DatatypeProperty,\n            owl:AnnotationProperty,\n            owl:OntologyProperty\n          )\n        )\n        FILTER NOT EXISTS { $this foaf:page ?page . }\n        FILTER NOT EXISTS { $this foaf:isPrimaryTopicOf ?topic . }\n      }\n    " .
_:genid2 <http://www.w3.org/ns/shacl#message> "Property declaration is missing both foaf:page and foaf:isPrimaryTopicOf." .
