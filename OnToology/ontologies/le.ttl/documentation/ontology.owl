<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.softlang.org/ontologies/le#"
     xml:base="http://www.softlang.org/ontologies/le"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:tbox="http://www.softlang.org/ontologies/tbox#">
    <owl:Ontology rdf:about="http://www.softlang.org/ontologies/le">
        <owl:imports rdf:resource="http://www.softlang.org/ontologies/tbox"/>
        <tbox:commentingPolicy xml:lang="en">See http://www.softlang.org/ontologies/tbox -- the same policy applies here.</tbox:commentingPolicy>
        <tbox:formattingPolicy xml:lang="en">See http://www.softlang.org/ontologies/tbox -- the same policy applies here.</tbox:formattingPolicy>
        <tbox:linkingPolicy xml:lang="en">See http://www.softlang.org/ontologies/tbox -- the same policy applies here.</tbox:linkingPolicy>
        <tbox:metamodelingPolicy xml:lang="en">See http://www.softlang.org/ontologies/tbox -- the same policy applies here.</tbox:metamodelingPolicy>
        <rdfs:comment xml:lang="en">Programming languages are maintained in the pe module; this module keeps non-programming software languages and broad language-kind taxonomies.</rdfs:comment>
        <rdfs:comment xml:lang="en">Sub-ontology / ABox for software languages</rdfs:comment>
    </owl:Ontology>
    


