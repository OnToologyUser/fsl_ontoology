    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotations
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#CompositeConcept">
        <rdfs:comment xml:lang="en">a language concept as a composite of other language concepts</rdfs:comment>
        <rdfs:label xml:lang="en">Composite concept</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Category:Programming_language_concepts"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#EngineeringActivity">
        <rdfs:comment xml:lang="en">Root class for software engineering activity types.</rdfs:comment>
        <rdfs:label xml:lang="en">Engineering activity</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Software_development_process"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#ImplementationMechanismConcept">
        <rdfs:comment xml:lang="en">a more realization/implementation-oriented category of language concepts</rdfs:comment>
        <rdfs:label xml:lang="en">Implementation mechanism concept</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Category:Programming_language_concepts"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#LanguageConcept">
        <rdfs:comment xml:lang="en">concept associated with a language framework such as programming-language concepts</rdfs:comment>
        <rdfs:label xml:lang="en">Language concept</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Category:Programming_language_concepts"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#LanguageConceptApplicability">
        <rdfs:comment xml:lang="en">qualifier for how directly a language concept applies to a language</rdfs:comment>
        <rdfs:label xml:lang="en">Language concept applicability</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Category:Programming_language_concepts"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#LanguageSupportAssertion">
        <rdfs:comment xml:lang="en">reified assertion that a language supports a language concept, optionally qualified</rdfs:comment>
        <rdfs:label xml:lang="en">Language support assertion</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Category:Programming_language_concepts"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#LanguageSupportKind">
        <rdfs:comment xml:lang="en">kind of support that a language provides for a language concept</rdfs:comment>
        <rdfs:label xml:lang="en">Language support kind</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Category:Programming_language_concepts"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#MethodologicalApproach">
        <rdfs:comment xml:lang="en">class of formal entities that represent methodological orientations, techniques, or styles of treatment used in the study or engineering of software languages and related formalisms</rdfs:comment>
        <rdfs:label xml:lang="en">Methodological approach</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#SoftwareArtifact">
        <rdfs:comment xml:lang="en">Software artifact kind used to classify the characteristic artifacts of a technological space</rdfs:comment>
        <rdfs:label xml:lang="en">Software artifact</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#SoftwareLanguage">
        <rdfs:comment xml:lang="en">Concrete software languages (e.g., XML, SQL, OWL) are represented as individuals of this class. Language families are represented as subclasses. Artifact kinds capture the kinds of artifacts written in such languages.</rdfs:comment>
        <rdfs:label xml:lang="en">Software language</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Software_language"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#SoftwareTool">
        <rdfs:label xml:lang="en">Software tool</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Programming_tool"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#SubjectArea">
        <rdfs:comment xml:lang="en">research or application area relevant to the foundations of software languages and related disciplines</rdfs:comment>
        <rdfs:label xml:lang="en">Subject area</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#TechnologicalSpace">
        <rdfs:comment xml:lang="en">Technological spaces are families of related software-language technologies that share characteristic artifact kinds, metalanguages, tools, conformance relations, skills, and communities of practice. A technological space is not just a single language or formalism, but a working context in which artifacts are defined, manipulated, queried, transformed, validated, exchanged, and executed according to characteristic principles. This class represents such ecosystems.</rdfs:comment>
        <rdfs:label xml:lang="en">Technological space</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#assertedForConcept">
        <rdfs:comment xml:lang="en">Relates a reified assertion about language concepts with the concept</rdfs:comment>
        <rdfs:label xml:lang="en">Asserted for concept</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Category:Programming_language_concepts"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#assertedForLanguage">
        <rdfs:comment xml:lang="en">Relates a reified assertion about language concepts with the language</rdfs:comment>
        <rdfs:label xml:lang="en">Asserted for language</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Category:Programming_language_concepts"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#classifies">
        <rdfs:comment xml:lang="en">Relates an artifact to another artifact in the generalized sense of metamodels classifying models</rdfs:comment>
        <rdfs:label xml:lang="en">classifies</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Metamodeling"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#commentingPolicy">
        <rdfs:comment xml:lang="en">Documents the ontology-wide expectation regarding commenting</rdfs:comment>
        <rdfs:label xml:lang="en">Commenting policy</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Guideline"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#conformsTo">
        <rdfs:comment xml:lang="en">Relates an artifact to another artifact in the generalized sense of models conforming to metamodels</rdfs:comment>
        <rdfs:label xml:lang="en">conforms to</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Metamodeling"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#critique">
        <rdfs:comment xml:lang="en">Describes the problem, concern, or critique expressed by an issue</rdfs:comment>
        <rdfs:label xml:lang="en">critique</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Issue_tracking_system"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#defines">
        <rdfs:comment xml:lang="en">Relates an artifact to a language in the sense of a definition (specification)</rdfs:comment>
        <rdfs:label xml:lang="en">defines</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Programming_language_specification"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#elementOf">
        <rdfs:comment xml:lang="en">Relates an artifact to a language in the set-theoretic sense</rdfs:comment>
        <rdfs:label xml:lang="en">element of</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Membership_function_(mathematics)"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#extends">
        <rdfs:comment xml:lang="en">Relates a software language to another software language that it extends or generalizes</rdfs:comment>
        <rdfs:label xml:lang="en">extends</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/N/A"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#formattingPolicy">
        <rdfs:comment xml:lang="en">Documents the ontology-wide expectation regarding formatting</rdfs:comment>
        <rdfs:label xml:lang="en">Formatting policy</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Guideline"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#hasAffectedArtifact">
        <rdfs:comment xml:lang="en">Relates an activity or a tool to an artifact kind that it typically affects (thereby complementing in- and output)</rdfs:comment>
        <rdfs:label xml:lang="en">has affected artifact</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Artifact_(software_development)"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#hasApplicability">
        <rdfs:comment xml:lang="en">Relates a reified assertion about language concepts with the applicability</rdfs:comment>
        <rdfs:label xml:lang="en">Has applicability</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Category:Programming_language_concepts"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#hasArea">
        <rdfs:comment xml:lang="en">Relates an entity to an important subject area of interest</rdfs:comment>
        <rdfs:label xml:lang="en">has area</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Academic_discipline"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#hasArtifact">
        <rdfs:comment xml:lang="en">Relates a technological space to a kind of artifact that it is concerned with</rdfs:comment>
        <rdfs:label xml:lang="en">has artifact</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Artifact_(software_development)"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#hasBibTeX">
        <rdfs:comment xml:lang="en">Relates an entity to the BibTeX key of a bibliographic entry that documents, discusses, or supports it</rdfs:comment>
        <rdfs:label xml:lang="en">has BibTeX</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Annotated_bibliography"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#hasComponent">
        <rdfs:comment xml:lang="en">Relates a composite language concept to a component</rdfs:comment>
        <rdfs:label xml:lang="en">Has component</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Category:Programming_language_concepts"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#hasDominantForm">
        <rdfs:comment xml:lang="en">Relates a language concept to a dominated form</rdfs:comment>
        <rdfs:label xml:lang="en">Has dominant form</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Category:Programming_language_concepts"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#hasElement">
        <rdfs:comment xml:lang="en">Relates a language to an artifact in the set-theoretic sense</rdfs:comment>
        <rdfs:label xml:lang="en">has element</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Membership_function_(mathematics)"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#hasInputArtifact">
        <rdfs:comment xml:lang="en">Relates an activity or a tool to an artifact kind that it typically requires or consumes as input</rdfs:comment>
        <rdfs:label xml:lang="en">has input artifact</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Artifact_(software_development)"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#hasOutputArtifact">
        <rdfs:comment xml:lang="en">Relates an activity or a tool to an artifact kind that it typically produces as output</rdfs:comment>
        <rdfs:label xml:lang="en">has output artifact</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Artifact_(software_development)"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#hasPrimaryComponent">
        <rdfs:comment xml:lang="en">Relates a composite language concept to a (primary) component</rdfs:comment>
        <rdfs:label xml:lang="en">Has primary component</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Category:Programming_language_concepts"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/tbox#hasPrimaryMechanism">
        <rdfs:comment xml:lang="en">Relates a reified assertion about language concepts with the primary mechanism for realization</rdfs:comment>
        <rdfs:label xml:lang="en">Has primary mechanism</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Category:Programming_language_concepts"/>
    </rdf:Description>
