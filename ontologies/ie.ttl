@prefix : <http://www.softlang.org/ontologies/ie#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tbox: <http://www.softlang.org/ontologies/tbox#> .
@prefix ae: <http://www.softlang.org/ontologies/ae#> .
@prefix ce: <http://www.softlang.org/ontologies/ce#> .
@prefix fe: <http://www.softlang.org/ontologies/fe#> .
@prefix le: <http://www.softlang.org/ontologies/le#> .
@prefix pe: <http://www.softlang.org/ontologies/pe#> .
@prefix te: <http://www.softlang.org/ontologies/te#> .

<http://www.softlang.org/ontologies/ie> a owl:Ontology ;
    tbox:commentingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
    tbox:formattingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
    tbox:linkingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
    tbox:metamodelingPolicy "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
    rdfs:comment "Sub-ontology / ABox for issue entities. Resource-level issues use tbox:target. Assertion-level issues use tbox:subject, tbox:predicate, and tbox:object to designate the roles of resources in the reviewed assertion."@en ;
    owl:imports <http://www.softlang.org/ontologies/tbox> .

:SupportsNameClashIssue a tbox:IssueEntity ;
    tbox:target tbox:targets ;
    tbox:target tbox:supports ;
    tbox:critique "The former tool-to-language property tbox:supports clashed by name with the language-to-concept support relation. The two relations have different domains, ranges, and intended meanings, so sharing the local name supports made the vocabulary ambiguous."@en ;
    tbox:suggestion "Use tbox:targets for the tool-to-language relation, with tbox:isTargetedBy as its inverse. Reserve tbox:supports for the language-to-concept relation."@en .

:LanguageConceptsNamespaceIssue a tbox:IssueEntity ;
    tbox:target tbox:LanguageConcept ;
    tbox:target tbox:CompositeConcept ;
    tbox:target tbox:LanguageSupportKind ;
    tbox:target tbox:LanguageSupportAssertion ;
    tbox:target tbox:LanguageConceptApplicability ;
    tbox:target tbox:ImplementationMechanismConcept ;
    tbox:target tbox:supports ;
    tbox:target tbox:nativelySupports ;
    tbox:target tbox:standardlySupports ;
    tbox:target tbox:assertedForConcept ;
    tbox:target tbox:assertedForLanguage ;
    tbox:target tbox:hasDominantForm ;
    tbox:target tbox:hasPrimaryMechanism ;
    tbox:target tbox:hasApplicability ;
    tbox:target tbox:hasComponent ;
    tbox:target tbox:hasPrimaryComponent ;
    tbox:target tbox:hasSecondaryComponent ;
    tbox:target tbox:hasSupportKind ;
    tbox:critique "The schema-level language-concept classes and properties now belong to the shared tbox vocabulary. Concrete language-concept individuals remain in ce and are typed with the corresponding tbox classes."@en ;
    tbox:suggestion "Keep the targeted class and property declarations in tbox. Use tbox references for schema vocabulary, and use ce references only for concrete concepts and concept qualifiers."@en ;
    tbox:resolveAfter :SupportsNameClashIssue .

:ModuleImportIssue a tbox:IssueEntity ;
    tbox:target <http://www.softlang.org/ontologies/ae> ;
    tbox:target <http://www.softlang.org/ontologies/le> ;
    tbox:target <http://www.softlang.org/ontologies/pe> ;
    tbox:target <http://www.softlang.org/ontologies/te> ;
    tbox:critique "Modules ae, le, pe, and te imported domain modules in addition to tbox. Under the intended module architecture, non-root ABox modules should import only tbox; cross-module references should not require owl:imports."@en ;
    tbox:suggestion "Remove ae -> pe, le -> ce, pe -> ce, and te -> pe imports. Keep only imports of tbox in these modules, and verify that cross-namespace references resolve through the aggregate fsl ontology."@en ;
    tbox:resolveAfter :LanguageConceptsNamespaceIssue .
