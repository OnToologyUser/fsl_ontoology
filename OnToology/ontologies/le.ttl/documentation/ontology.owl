    <!-- http://www.softlang.org/ontologies/le#ATL -->


    <owl:NamedIndividual rdf:about="http://www.softlang.org/ontologies/le#ATL">
        <rdf:type rdf:resource="http://www.softlang.org/ontologies/le#ModelTransformationLanguage"/>
        <rdf:type rdf:resource="http://www.softlang.org/ontologies/tbox#LanguageEntity"/>
        <tbox:hasArea rdf:resource="http://www.softlang.org/ontologies/ce#MDE"/>
        <tbox:hasArea rdf:resource="http://www.softlang.org/ontologies/ce#SE"/>
        <tbox:hasArea rdf:resource="http://www.softlang.org/ontologies/ce#SLE"/>
        <tbox:hasSpace rdf:resource="http://www.softlang.org/ontologies/ce#Modelware"/>
        <tbox:supports rdf:resource="http://www.softlang.org/ontologies/ce#Abstraction"/>
        <tbox:supports rdf:resource="http://www.softlang.org/ontologies/ce#DataAbstraction"/>
        <tbox:supports rdf:resource="http://www.softlang.org/ontologies/ce#ModelingConcept"/>
        <tbox:supports rdf:resource="http://www.softlang.org/ontologies/ce#TransformationConcept"/>
        <rdfs:label xml:lang="en">ATL</rdfs:label>
        <foaf:isPrimaryTopicOf rdf:resource="https://en.wikipedia.org/wiki/ATLAS_Transformation_Language"/>
    </owl:NamedIndividual>
    


    <!-- http://www.softlang.org/ontologies/le#BNF -->


