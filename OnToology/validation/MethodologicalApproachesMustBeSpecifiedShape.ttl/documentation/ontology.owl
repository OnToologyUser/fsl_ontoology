    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.softlang.org/ontologies/ve#MethodologicalApproachesMustBeSpecifiedShape -->


    <NamedIndividual rdf:about="http://www.softlang.org/ontologies/ve#MethodologicalApproachesMustBeSpecifiedShape">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#NodeShape"/>
        <rdfs:comment>TODO</rdfs:comment>
        <shacl:property rdf:nodeID="genid2"/>
        <shacl:target rdf:resource="http://www.softlang.org/ontologies/ve#MethodologicalApproachesMustBeSpecifiedTarget"/>
    </NamedIndividual>
    <rdf:Description rdf:nodeID="genid2">
        <shacl:path>
            <rdf:Description>
                <shacl:alternativePath>
                    <rdf:Description/>
                </shacl:alternativePath>
            </rdf:Description>
        </shacl:path>
        <shacl:qualifiedMinCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</shacl:qualifiedMinCount>
        <shacl:qualifiedValueShape>
            <rdf:Description>
                <shacl:class rdf:resource="http://www.softlang.org/ontologies/tbox#Entity"/>
            </rdf:Description>
        </shacl:qualifiedValueShape>
    </rdf:Description>
    


    <!-- http://www.softlang.org/ontologies/ve#MethodologicalApproachesMustBeSpecifiedTarget -->


    <NamedIndividual rdf:about="http://www.softlang.org/ontologies/ve#MethodologicalApproachesMustBeSpecifiedTarget">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#SPARQLTarget"/>
        <rdfs:comment>TODO</rdfs:comment>
        <shacl:select>
    PREFIX rdf: &lt;http://www.w3.org/1999/02/22-rdf-syntax-ns#&gt;
    PREFIX rdfs: &lt;http://www.w3.org/2000/01/rdf-schema#&gt;
    PREFIX fe:  &lt;http://www.softlang.org/ontologies/fe#&gt;

    SELECT ?this
    WHERE {
      ?this rdf:type fe:MethodologicalApproach .
      FILTER(?this NOT IN (
          fe:AbstractSyntaxDefinitionApproach,
      	  fe:AxiomaticSemantics,
          fe:DataValidation,
          fe:DesignByContract,
          fe:ModelTransformation,
          fe:RelationalModel
        )
      )
    }
  </shacl:select>
    </NamedIndividual>
    <rdf:Description>
        <shacl:inversePath rdf:resource="http://www.softlang.org/ontologies/tbox#serves"/>
    </rdf:Description>
</rdf:RDF>



