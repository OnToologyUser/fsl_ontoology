    <!-- http://www.softlang.org/ontologies/pe#Ada -->


    <owl:NamedIndividual rdf:about="http://www.softlang.org/ontologies/pe#Ada">
        <rdf:type rdf:resource="http://www.softlang.org/ontologies/pe#ProgrammingLanguage"/>
        <rdf:type rdf:resource="http://www.softlang.org/ontologies/tbox#LanguageEntity"/>
        <tbox:hasArea rdf:resource="http://www.softlang.org/ontologies/ce#PLT"/>
        <tbox:hasArea rdf:resource="http://www.softlang.org/ontologies/ce#SE"/>
        <tbox:hasArea rdf:resource="http://www.softlang.org/ontologies/ce#SLE"/>
        <tbox:hasSpace rdf:resource="http://www.softlang.org/ontologies/ce#Programware"/>
        <tbox:nativelySupports rdf:resource="http://www.softlang.org/ontologies/ce#DataAbstraction"/>
        <tbox:nativelySupports rdf:resource="http://www.softlang.org/ontologies/ce#Exceptions"/>
        <tbox:nativelySupports rdf:resource="http://www.softlang.org/ontologies/ce#ImperativeParadigm"/>
        <tbox:nativelySupports rdf:resource="http://www.softlang.org/ontologies/ce#ProceduralAbstraction"/>
        <tbox:nativelySupports rdf:resource="http://www.softlang.org/ontologies/ce#SharedMemoryConcurrency"/>
        <tbox:nativelySupports rdf:resource="http://www.softlang.org/ontologies/ce#StaticTyping"/>
        <tbox:nativelySupports rdf:resource="http://www.softlang.org/ontologies/ce#StrongTyping"/>
        <tbox:nativelySupports rdf:resource="http://www.softlang.org/ontologies/ce#TaskParallelism"/>
        <rdfs:comment xml:lang="en">statically typed language with strong support for reliability and concurrency</rdfs:comment>
        <rdfs:label xml:lang="en">Ada</rdfs:label>
        <foaf:isPrimaryTopicOf rdf:resource="https://dbpedia.org/resource/Ada_(programming_language)"/>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Ada_(programming_language)"/>
    </owl:NamedIndividual>
    


