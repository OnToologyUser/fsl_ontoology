:CompositeConcept rdfs:comment "a language concept as a composite of other language concepts"@en ;
                  rdfs:label "Composite concept"@en ;
                  <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Category:Programming_language_concepts> .


:EngineeringActivity rdfs:comment "Root class for software engineering activity types."@en ;
                     rdfs:label "Engineering activity"@en ;
                     <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Software_development_process> .


:ImplementationMechanismConcept rdfs:comment "a more realization/implementation-oriented category of language concepts"@en ;
                                rdfs:label "Implementation mechanism concept"@en ;
                                <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Category:Programming_language_concepts> .


:LanguageConcept rdfs:comment "concept associated with a language framework such as programming-language concepts"@en ;
                 rdfs:label "Language concept"@en ;
                 <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Category:Programming_language_concepts> .


:LanguageConceptApplicability rdfs:comment "qualifier for how directly a language concept applies to a language"@en ;
                              rdfs:label "Language concept applicability"@en ;
                              <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Category:Programming_language_concepts> .


:LanguageSupportAssertion rdfs:comment "reified assertion that a language supports a language concept, optionally qualified"@en ;
                          rdfs:label "Language support assertion"@en ;
                          <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Category:Programming_language_concepts> .


:LanguageSupportKind rdfs:comment "kind of support that a language provides for a language concept"@en ;
                     rdfs:label "Language support kind"@en ;
                     <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Category:Programming_language_concepts> .


:MethodologicalApproach rdfs:comment "class of formal entities that represent methodological orientations, techniques, or styles of treatment used in the study or engineering of software languages and related formalisms"@en ;
                        rdfs:label "Methodological approach"@en .


:SoftwareArtifact rdfs:comment "Software artifact kind used to classify the characteristic artifacts of a technological space"@en ;
                  rdfs:label "Software artifact"@en .


:SoftwareLanguage rdfs:comment "Concrete software languages (e.g., XML, SQL, OWL) are represented as individuals of this class. Language families are represented as subclasses. Artifact kinds capture the kinds of artifacts written in such languages."@en ;
                  rdfs:label "Software language"@en ;
                  <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Software_language> .


:SoftwareTool rdfs:label "Software tool"@en ;
              <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Programming_tool> .


:SubjectArea rdfs:comment "research or application area relevant to the foundations of software languages and related disciplines"@en ;
             rdfs:label "Subject area"@en .


:TechnologicalSpace rdfs:comment "Technological spaces are families of related software-language technologies that share characteristic artifact kinds, metalanguages, tools, conformance relations, skills, and communities of practice. A technological space is not just a single language or formalism, but a working context in which artifacts are defined, manipulated, queried, transformed, validated, exchanged, and executed according to characteristic principles. This class represents such ecosystems."@en ;
                    rdfs:label "Technological space"@en .


:assertedForConcept rdfs:comment "Relates a reified assertion about language concepts with the concept"@en ;
                    rdfs:label "Asserted for concept"@en ;
                    <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Category:Programming_language_concepts> .


:assertedForLanguage rdfs:comment "Relates a reified assertion about language concepts with the language"@en ;
                     rdfs:label "Asserted for language"@en ;
                     <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Category:Programming_language_concepts> .


:classifies rdfs:comment "Relates an artifact to another artifact in the generalized sense of metamodels classifying models"@en ;
            rdfs:label "classifies"@en ;
            <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Metamodeling> .


:commentingPolicy rdfs:comment "Documents the ontology-wide expectation regarding commenting"@en ;
                  rdfs:label "Commenting policy"@en ;
                  <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Guideline> .


:conformsTo rdfs:comment "Relates an artifact to another artifact in the generalized sense of models conforming to metamodels"@en ;
            rdfs:label "conforms to"@en ;
            <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Metamodeling> .


