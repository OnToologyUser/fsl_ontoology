<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
     xml:base="http://www.w3.org/2002/07/owl"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:shacl="http://www.w3.org/ns/shacl#">
    <Ontology/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/ns/shacl#message -->


    <AnnotationProperty rdf:about="http://www.w3.org/ns/shacl#message"/>
    


    <!-- http://www.w3.org/ns/shacl#select -->


    <AnnotationProperty rdf:about="http://www.w3.org/ns/shacl#select"/>
    


    <!-- http://www.w3.org/ns/shacl#sparql -->


    <AnnotationProperty rdf:about="http://www.w3.org/ns/shacl#sparql"/>
    


    <!-- http://www.w3.org/ns/shacl#targetSubjectsOf -->


    <AnnotationProperty rdf:about="http://www.w3.org/ns/shacl#targetSubjectsOf"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/ns/shacl#NodeShape -->


    <Class rdf:about="http://www.w3.org/ns/shacl#NodeShape"/>
    


    <!-- http://www.w3.org/ns/shacl#SPARQLConstraint -->


    <Class rdf:about="http://www.w3.org/ns/shacl#SPARQLConstraint"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.softlang.org/ontologies/ve#EngineeringActivitiesMustBeSpecifiedShape -->


    <NamedIndividual rdf:about="http://www.softlang.org/ontologies/ve#EngineeringActivitiesMustBeSpecifiedShape">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#NodeShape"/>
        <shacl:sparql rdf:nodeID="genid2"/>
        <shacl:targetSubjectsOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
    </NamedIndividual>
    <rdf:Description rdf:nodeID="genid2">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#SPARQLConstraint"/>
        <shacl:message>Each immediate subclass of ce:EngineeringActivity must have subclass witnesses sc1 and sc2 such that sc1 has an affected/input/output ArtifactEntity and sc2 has a supporting LanguageEntity or ToolEntity.</shacl:message>
        <shacl:select>
      PREFIX tbox: &lt;http://www.softlang.org/ontologies/tbox#&gt;
      PREFIX ce:   &lt;http://www.softlang.org/ontologies/ce#&gt;
      PREFIX rdf:  &lt;http://www.w3.org/1999/02/22-rdf-syntax-ns#&gt;
      PREFIX rdfs: &lt;http://www.w3.org/2000/01/rdf-schema#&gt;

      SELECT $this
      WHERE {
        # Focus only on immediate subclasses of ce:EngineeringActivity; defend against entailment
        $this rdfs:subClassOf ce:EngineeringActivity .
        FILTER NOT EXISTS {
          $this rdfs:subClassOf ?super .
          ?super rdfs:subClassOf ce:EngineeringActivity .
          FILTER(?super != ce:EngineeringActivity)
        }

        # TODO
        FILTER($this NOT IN (
            ce:OperationsAndMaintenanceActivity,
            ce:PlanningAndManagementActivity,
            ce:QualityAndGovernanceActivity,
            ce:ReleaseAndDeploymentActivity,
            ce:SupportActivity
          )
        )

        FILTER NOT EXISTS {
	  # Some subclasses sc1, sc2 of $this (direct or indirect, but proper)
          ?sc1 rdfs:subClassOf+ $this .
          ?sc2 rdfs:subClassOf+ $this .

          # sc1 must have one of the artifact links to an ArtifactEntity
          {
            ?sc1 tbox:hasAffectedArtifact ?a1 .
            ?a1 rdf:type tbox:ArtifactEntity .
          }
          UNION
          {
            ?sc1 tbox:hasInputArtifact ?a2 .
            ?a2 rdf:type tbox:ArtifactEntity .
          }
          UNION
          {
            ?sc1 tbox:hasOutputArtifact ?a3 .
            ?a3 rdf:type tbox:ArtifactEntity .
          }

          # sc2 must have one of the support links
          {
            ?sc2 tbox:hasSupportingLanguage ?l .
            ?l rdf:type tbox:LanguageEntity .
          }
          UNION
          {
            ?sc2 tbox:hasSupportingTool ?t .
            ?t rdf:type tbox:ToolEntity .
          }
        }
      }
    </shacl:select>
    </rdf:Description>
</rdf:RDF>



