[ {
  "@id" : "_:genid1",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ]
}, {
  "@id" : "_:genid2",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/ns/shacl#SPARQLConstraint"
  } ],
  "http://www.w3.org/ns/shacl#message" : [ {
    "@value" : "Each immediate subclass of ce:EngineeringActivity must have subclass witnesses sc1 and sc2 such that sc1 has an affected/input/output ArtifactEntity and sc2 has a supporting LanguageEntity or ToolEntity."
  } ],
  "http://www.w3.org/ns/shacl#select" : [ {
    "@value" : "\n      PREFIX tbox: <http://www.softlang.org/ontologies/tbox#>\n      PREFIX ce:   <http://www.softlang.org/ontologies/ce#>\n      PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\n      PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\n\n      SELECT $this\n      WHERE {\n        # Focus only on immediate subclasses of ce:EngineeringActivity; defend against entailment\n        $this rdfs:subClassOf ce:EngineeringActivity .\n        FILTER NOT EXISTS {\n          $this rdfs:subClassOf ?super .\n          ?super rdfs:subClassOf ce:EngineeringActivity .\n          FILTER(?super != ce:EngineeringActivity)\n        }\n\n        # TODO\n        FILTER($this NOT IN (\n            ce:OperationsAndMaintenanceActivity,\n            ce:PlanningAndManagementActivity,\n            ce:QualityAndGovernanceActivity,\n            ce:ReleaseAndDeploymentActivity,\n            ce:SupportActivity\n          )\n        )\n\n        FILTER NOT EXISTS {\n\t  # Some subclasses sc1, sc2 of $this (direct or indirect, but proper)\n          ?sc1 rdfs:subClassOf+ $this .\n          ?sc2 rdfs:subClassOf+ $this .\n\n          # sc1 must have one of the artifact links to an ArtifactEntity\n          {\n            ?sc1 tbox:hasAffectedArtifact ?a1 .\n            ?a1 rdf:type tbox:ArtifactEntity .\n          }\n          UNION\n          {\n            ?sc1 tbox:hasInputArtifact ?a2 .\n            ?a2 rdf:type tbox:ArtifactEntity .\n          }\n          UNION\n          {\n            ?sc1 tbox:hasOutputArtifact ?a3 .\n            ?a3 rdf:type tbox:ArtifactEntity .\n          }\n\n          # sc2 must have one of the support links\n          {\n            ?sc2 tbox:hasSupportingLanguage ?l .\n            ?l rdf:type tbox:LanguageEntity .\n          }\n          UNION\n          {\n            ?sc2 tbox:hasSupportingTool ?t .\n            ?t rdf:type tbox:ToolEntity .\n          }\n        }\n      }\n    "
  } ]
}, {
  "@id" : "http://www.softlang.org/ontologies/ve#EngineeringActivitiesMustBeSpecifiedShape",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/ns/shacl#NodeShape"
  } ],
  "http://www.w3.org/ns/shacl#sparql" : [ {
    "@id" : "_:genid2"
  } ],
  "http://www.w3.org/ns/shacl#targetSubjectsOf" : [ {
    "@id" : "http://www.w3.org/2000/01/rdf-schema#subClassOf"
  } ]
}, {
  "@id" : "http://www.w3.org/ns/shacl#NodeShape",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ]
}, {
  "@id" : "http://www.w3.org/ns/shacl#SPARQLConstraint",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ]
}, {
  "@id" : "http://www.w3.org/ns/shacl#message",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.w3.org/ns/shacl#select",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.w3.org/ns/shacl#sparql",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
}, {
  "@id" : "http://www.w3.org/ns/shacl#targetSubjectsOf",
  "@type" : [ "http://www.w3.org/2002/07/owl#AnnotationProperty" ]
} ]