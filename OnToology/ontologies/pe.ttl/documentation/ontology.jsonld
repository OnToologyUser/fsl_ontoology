[ {
  "@id" : "http://www.softlang.org/ontologies/pe",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://www.softlang.org/ontologies/pe#profilingPolicy" : [ {
    "@language" : "en",
    "@value" : "\nProgramming-language profiling uses only native support and standard-library support.\nRefined concepts are asserted selectively rather than exhaustively.\nNo support is recorded for mere encodings or otherwise insignificant realizations.\nRefined support is not inherited automatically from coarse support.\nSupport assertions are qualified only when especially representative or potentially ambiguous.\nBorderline cases may be documented using skos:note.\nParadigm-based subclassing of programming languages is not used; paradigms are represented via concept support.\n"
  } ],
  "http://www.softlang.org/ontologies/tbox#commentingPolicy" : [ {
    "@language" : "en",
    "@value" : "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."
  } ],
  "http://www.softlang.org/ontologies/tbox#formattingPolicy" : [ {
    "@language" : "en",
    "@value" : "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."
  } ],
  "http://www.softlang.org/ontologies/tbox#linkingPolicy" : [ {
    "@language" : "en",
    "@value" : "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."
  } ],
  "http://www.softlang.org/ontologies/tbox#metamodelingPolicy" : [ {
    "@language" : "en",
    "@value" : "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Sub-ontology / ABox for programming-language concepts and programming languages"
  } ],
  "http://www.w3.org/2002/07/owl#imports" : [ {
    "@id" : "http://www.softlang.org/ontologies/tbox"
  } ]
