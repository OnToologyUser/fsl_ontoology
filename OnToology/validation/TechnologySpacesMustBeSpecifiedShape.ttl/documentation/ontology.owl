    <!-- http://www.softlang.org/ontologies/ve#TechnologySpacesMustBeSpecifiedShape -->


    <NamedIndividual rdf:about="http://www.softlang.org/ontologies/ve#TechnologySpacesMustBeSpecifiedShape">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#NodeShape"/>
