###  http://www.softlang.org/ontologies/ce#XMLware
:XMLware rdf:type owl:NamedIndividual ,
                  <http://www.softlang.org/ontologies/tbox#ConceptualEntity> ,
                  <http://www.softlang.org/ontologies/tbox#TechnologicalSpace> ;
         <http://www.softlang.org/ontologies/tbox#hasArtifact> <http://www.softlang.org/ontologies/ae#XMLDocumentArtifact> ,
                                                               <http://www.softlang.org/ontologies/ae#XMLSchemaArtifact> ;
         <http://www.softlang.org/ontologies/tbox#hasTool> <http://www.softlang.org/ontologies/te#QueryProcessor> ,
                                                           <http://www.softlang.org/ontologies/te#TransformationEngine> ,
                                                           <http://www.softlang.org/ontologies/te#Validator> ,
                                                           <http://www.softlang.org/ontologies/te#XMLProcessor> ;
         rdfs:comment "technological space centered on XML documents, XML schemas, XML querying, XML transformation, and XML processing"@en ;
         rdfs:label "XMLware"@en .


