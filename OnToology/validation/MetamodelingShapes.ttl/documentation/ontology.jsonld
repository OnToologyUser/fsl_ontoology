    "@value" : "Anything below the immediate subclasses of tbox:LanguageEntity must be of type tbox:LanguageEntity."
  } ],
  "http://www.w3.org/ns/shacl#select" : [ {
    "@value" : "\n      PREFIX tbox: <http://www.softlang.org/ontologies/tbox#>\n      PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\n      PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\n\n      SELECT $this\n      WHERE {\n        FILTER($this != owl:Nothing)\n      \t$this rdfs:subClassOf ?super .\n        ?super rdfs:subClassOf+ tbox:LanguageEntity .\n        FILTER NOT EXISTS {\n          $this rdf:type tbox:LanguageEntity .\n        }\n      }\n    "
  } ]
