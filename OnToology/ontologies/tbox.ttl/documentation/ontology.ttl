@prefix : <http://www.softlang.org/ontologies/tbox#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.softlang.org/ontologies/tbox#> .

<http://www.softlang.org/ontologies/tbox> rdf:type owl:Ontology ;
                                           :commentingPolicy "All rdfs:comments must start in upper case."@en ;
                                           :formattingPolicy "TTL syntax is to be used so that triples are grouped by shared subject. Default namespace (\":\") instead of explicit prefixes should be used, whenever possible. The required order in ontology files is: prefix declarations first, followed by the ontology header, then classes ordered by class name, then properties ordered by property name, and finally all remaining assertions ordered by subject name. Any serialization of the ontology should obey this formatting policy."@en ;
                                           :linkingPolicy "All important classes and individuals should link to Wikipedia. Use foaf:isPrimaryTopicOf where possible. Use foaf:page otherwise. Link to https://en.wikipedia.org/wiki/N/A to express that no useful page could be determined."@en ;
                                           :metamodelingPolicy "Punning/metamodeling is used systematically. Every class that is a subclass of an Entity subclass should also be explicitly typed as that Entity subclass. Every individual whose asserted type derives from an Entity subclass should also be explicitly typed as that Entity subclass. Example: le:QueryLanguage a tbox:LanguageEntity . Example: le:SQL a tbox:LanguageEntity . This expectation should be maintained as the ontology evolves."@en ;
                                           rdfs:comment "Shared TBox of the FSL ontology"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://www.softlang.org/ontologies/tbox#commentingPolicy
:commentingPolicy rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#formattingPolicy
:formattingPolicy rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#linkingPolicy
:linkingPolicy rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#metamodelingPolicy
:metamodelingPolicy rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#object
:object rdfs:comment "Identifies the object constituent of an issue when the issue concerns a particular assertion; this property designates object role rather than the overall issue target"@en ;
        rdfs:label "object"@en ;
        <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Issue_tracking_system> ;
        rdf:type owl:AnnotationProperty ;
        rdfs:subPropertyOf rdf:object ;
        rdfs:domain :IssueEntity .


###  http://www.softlang.org/ontologies/tbox#predicate
:predicate rdfs:comment "Identifies the predicate constituent of an issue when the issue concerns a particular assertion; this property designates predicate role rather than the overall issue target"@en ;
           rdfs:label "predicate"@en ;
           <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Issue_tracking_system> ;
           rdf:type owl:AnnotationProperty ;
           rdfs:subPropertyOf rdf:predicate ;
           rdfs:domain :IssueEntity .


###  http://www.softlang.org/ontologies/tbox#subject
:subject rdfs:comment "Identifies the subject constituent of an issue when the issue concerns a particular assertion; this property designates subject role rather than the overall issue target"@en ;
         rdfs:label "subject"@en ;
         <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Issue_tracking_system> ;
         rdf:type owl:AnnotationProperty ;
         rdfs:subPropertyOf rdf:subject ;
         rdfs:domain :IssueEntity .


###  http://www.softlang.org/ontologies/tbox#target
:target rdfs:comment "Identifies the primary resource that an issue is about, such as a reviewed resource or an ontology/module addressed as a whole; assertion-level issues are instead designated through subject, predicate, and object"@en ;
        rdfs:label "target"@en ;
        <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Issue_tracking_system> ;
        rdf:type owl:AnnotationProperty ;
        rdfs:domain :IssueEntity .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#object
rdf:object rdf:type owl:AnnotationProperty .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#predicate
rdf:predicate rdf:type owl:AnnotationProperty .


###  http://www.w3.org/1999/02/22-rdf-syntax-ns#subject
rdf:subject rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.softlang.org/ontologies/tbox#assertedForConcept
:assertedForConcept rdf:type owl:ObjectProperty ;
                    rdfs:domain :LanguageSupportAssertion ;
                    rdfs:range :LanguageConcept .


###  http://www.softlang.org/ontologies/tbox#assertedForLanguage
:assertedForLanguage rdf:type owl:ObjectProperty ;
                     rdfs:domain :LanguageSupportAssertion ;
                     rdfs:range :LanguageEntity .


###  http://www.softlang.org/ontologies/tbox#classifies
:classifies rdf:type owl:ObjectProperty ;
            owl:inverseOf :conformsTo ;
            rdfs:domain :ArtifactEntity ;
            rdfs:range :ArtifactEntity .


###  http://www.softlang.org/ontologies/tbox#conformsTo
:conformsTo rdf:type owl:ObjectProperty ;
            rdfs:domain :ArtifactEntity ;
            rdfs:range :ArtifactEntity .


###  http://www.softlang.org/ontologies/tbox#defines
:defines rdf:type owl:ObjectProperty ;
         owl:inverseOf :isDefinedBy ;
         rdfs:domain :ArtifactEntity ;
         rdfs:range :LanguageEntity .


###  http://www.softlang.org/ontologies/tbox#elementOf
:elementOf rdf:type owl:ObjectProperty ;
           rdfs:domain :ArtifactEntity ;
           rdfs:range :LanguageEntity .


###  http://www.softlang.org/ontologies/tbox#extends
:extends rdf:type owl:ObjectProperty ;
         rdfs:domain :SoftwareLanguage ;
         rdfs:range :SoftwareLanguage .


###  http://www.softlang.org/ontologies/tbox#hasAffectedArtifact
:hasAffectedArtifact rdf:type owl:ObjectProperty ;
                     rdfs:domain [ rdf:type owl:Class ;
                                   owl:unionOf ( :EngineeringActivity
                                                 :ToolEntity
                                               )
                                 ] ;
                     rdfs:range :ArtifactEntity .


###  http://www.softlang.org/ontologies/tbox#hasApplicability
:hasApplicability rdf:type owl:ObjectProperty ;
                  rdfs:domain :LanguageSupportAssertion ;
                  rdfs:range :LanguageConceptApplicability .


###  http://www.softlang.org/ontologies/tbox#hasArea
:hasArea rdf:type owl:ObjectProperty ;
         rdfs:domain :Entity ;
         rdfs:range :SubjectArea .


###  http://www.softlang.org/ontologies/tbox#hasArtifact
:hasArtifact rdf:type owl:ObjectProperty ;
             owl:inverseOf :isArtifactOf ;
             rdfs:domain :TechnologicalSpace ;
             rdfs:range :ArtifactEntity .


###  http://www.softlang.org/ontologies/tbox#hasComponent
:hasComponent rdf:type owl:ObjectProperty ;
              rdfs:domain :CompositeConcept ;
              rdfs:range :LanguageConcept .


###  http://www.softlang.org/ontologies/tbox#hasDominantForm
:hasDominantForm rdf:type owl:ObjectProperty ;
                 rdfs:domain :LanguageSupportAssertion ;
                 rdfs:range :LanguageConcept .


###  http://www.softlang.org/ontologies/tbox#hasElement
:hasElement rdf:type owl:ObjectProperty ;
            owl:inverseOf :elementOf ;
            rdfs:domain :LanguageEntity ;
            rdfs:range :ArtifactEntity .


###  http://www.softlang.org/ontologies/tbox#hasInputArtifact
:hasInputArtifact rdf:type owl:ObjectProperty ;
                  rdfs:domain [ rdf:type owl:Class ;
                                owl:unionOf ( :EngineeringActivity
                                              :ToolEntity
                                            )
                              ] ;
                  rdfs:range :ArtifactEntity .


###  http://www.softlang.org/ontologies/tbox#hasOutputArtifact
:hasOutputArtifact rdf:type owl:ObjectProperty ;
                   rdfs:domain [ rdf:type owl:Class ;
                                 owl:unionOf ( :EngineeringActivity
                                               :ToolEntity
                                             )
                               ] ;
                   rdfs:range :ArtifactEntity .


###  http://www.softlang.org/ontologies/tbox#hasPart
:hasPart rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf :uses ;
         rdf:type owl:AsymmetricProperty ,
                  owl:IrreflexiveProperty ;
         rdfs:domain :Entity ;
         rdfs:range :Entity ;
         rdfs:comment "Relates an ontology entity to another ontology entity that is a structural part or constituent of it"@en ;
         rdfs:label "has part"@en ;
         <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/Mereology> .


###  http://www.softlang.org/ontologies/tbox#hasPrimaryComponent
:hasPrimaryComponent rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf :hasComponent ;
                     rdfs:domain :CompositeConcept ;
                     rdfs:range :LanguageConcept .


###  http://www.softlang.org/ontologies/tbox#hasPrimaryMechanism
:hasPrimaryMechanism rdf:type owl:ObjectProperty ;
                     rdfs:domain :LanguageSupportAssertion ;
                     rdfs:range :ImplementationMechanismConcept .


###  http://www.softlang.org/ontologies/tbox#hasSecondaryComponent
:hasSecondaryComponent rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf :hasComponent ;
                       rdfs:domain :CompositeConcept ;
                       rdfs:range :LanguageConcept .


###  http://www.softlang.org/ontologies/tbox#hasSpace
:hasSpace rdf:type owl:ObjectProperty ;
          rdfs:domain :Entity ;
          rdfs:range :TechnologicalSpace .


###  http://www.softlang.org/ontologies/tbox#hasSupportKind
:hasSupportKind rdf:type owl:ObjectProperty ;
                rdfs:domain :LanguageSupportAssertion ;
                rdfs:range :LanguageSupportKind .


###  http://www.softlang.org/ontologies/tbox#hasSupportingLanguage
:hasSupportingLanguage rdf:type owl:ObjectProperty ;
                       rdfs:domain :EngineeringActivity ;
                       rdfs:range :LanguageEntity .


###  http://www.softlang.org/ontologies/tbox#hasSupportingTool
:hasSupportingTool rdf:type owl:ObjectProperty ;
                   rdfs:domain :EngineeringActivity ;
                   rdfs:range :ToolEntity .


###  http://www.softlang.org/ontologies/tbox#hasTool
:hasTool rdf:type owl:ObjectProperty ;
         rdfs:domain :TechnologicalSpace ;
         rdfs:range :ToolEntity .


###  http://www.softlang.org/ontologies/tbox#isAreaOf
:isAreaOf rdf:type owl:ObjectProperty ;
          owl:inverseOf :hasArea ;
          rdfs:domain :SubjectArea ;
          rdfs:range :Entity .


###  http://www.softlang.org/ontologies/tbox#isArtifactOf
:isArtifactOf rdf:type owl:ObjectProperty ;
              rdfs:domain :ArtifactEntity ;
              rdfs:range :TechnologicalSpace .


###  http://www.softlang.org/ontologies/tbox#isDefinedBy
:isDefinedBy rdf:type owl:ObjectProperty ;
             rdfs:domain :LanguageEntity ;
             rdfs:range :ArtifactEntity .


###  http://www.softlang.org/ontologies/tbox#isExtendedBy
:isExtendedBy rdf:type owl:ObjectProperty ;
              owl:inverseOf :extends ;
              rdfs:domain :SoftwareLanguage ;
              rdfs:range :SoftwareLanguage .


###  http://www.softlang.org/ontologies/tbox#isPartOf
:isPartOf rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :isUsedBy ;
          owl:inverseOf :hasPart ;
          rdf:type owl:AsymmetricProperty ,
                   owl:IrreflexiveProperty ;
          rdfs:domain :Entity ;
          rdfs:range :Entity ;
          rdfs:comment "Relates an ontology entity to another ontology entity of which it is a structural part or constituent"@en ;
          rdfs:label "is part of"@en ;
          <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/Mereology> .


###  http://www.softlang.org/ontologies/tbox#isProcessedBy
:isProcessedBy rdf:type owl:ObjectProperty ;
               owl:inverseOf :processes ;
               rdfs:domain :ArtifactEntity ;
               rdfs:range :ToolEntity .


###  http://www.softlang.org/ontologies/tbox#isServedBy
:isServedBy rdf:type owl:ObjectProperty ;
            rdfs:domain :MethodologicalApproach ;
            rdfs:range :Entity .


###  http://www.softlang.org/ontologies/tbox#isSpaceOf
:isSpaceOf rdf:type owl:ObjectProperty ;
           owl:inverseOf :hasSpace ;
           rdfs:domain :TechnologicalSpace ;
           rdfs:range :Entity .


###  http://www.softlang.org/ontologies/tbox#isSpecifiedBy
:isSpecifiedBy rdf:type owl:ObjectProperty ;
               rdfs:domain :FormalEntity ;
               rdfs:range :MethodologicalApproach .


###  http://www.softlang.org/ontologies/tbox#isTargetedBy
:isTargetedBy rdf:type owl:ObjectProperty ;
              owl:inverseOf :targets ;
              rdfs:domain :LanguageEntity ;
              rdfs:range :ToolEntity .


###  http://www.softlang.org/ontologies/tbox#isToolOf
:isToolOf rdf:type owl:ObjectProperty ;
          owl:inverseOf :hasTool ;
          rdfs:domain :ToolEntity ;
          rdfs:range :TechnologicalSpace .


###  http://www.softlang.org/ontologies/tbox#isUsedBy
:isUsedBy rdf:type owl:ObjectProperty ;
          owl:inverseOf :uses ;
          rdfs:domain :Entity ;
          rdfs:range :Entity .


###  http://www.softlang.org/ontologies/tbox#nativelySupports
:nativelySupports rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :supports ;
                  rdfs:domain :LanguageEntity ;
                  rdfs:range :LanguageConcept .


###  http://www.softlang.org/ontologies/tbox#processes
:processes rdf:type owl:ObjectProperty ;
           rdfs:domain :ToolEntity ;
           rdfs:range :ArtifactEntity .


###  http://www.softlang.org/ontologies/tbox#resolveAfter
:resolveAfter rdf:type owl:ObjectProperty ;
              rdfs:domain :IssueEntity ;
              rdfs:range :IssueEntity .


###  http://www.softlang.org/ontologies/tbox#serves
:serves rdf:type owl:ObjectProperty ;
        owl:inverseOf :isServedBy ;
        rdfs:domain :Entity ;
        rdfs:range :MethodologicalApproach .


###  http://www.softlang.org/ontologies/tbox#specifies
:specifies rdf:type owl:ObjectProperty ;
           owl:inverseOf :isSpecifiedBy ;
           rdfs:domain :MethodologicalApproach ;
           rdfs:range :FormalEntity .


###  http://www.softlang.org/ontologies/tbox#standardlySupports
:standardlySupports rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :supports ;
                    rdfs:domain :LanguageEntity ;
                    rdfs:range :LanguageConcept .


###  http://www.softlang.org/ontologies/tbox#supports
:supports rdf:type owl:ObjectProperty ;
          rdfs:domain :LanguageEntity ;
          rdfs:range :LanguageConcept .


###  http://www.softlang.org/ontologies/tbox#targets
:targets rdf:type owl:ObjectProperty ;
         rdfs:domain :ToolEntity ;
         rdfs:range :LanguageEntity .


###  http://www.softlang.org/ontologies/tbox#uses
:uses rdf:type owl:ObjectProperty ;
      rdfs:domain :Entity ;
      rdfs:range :Entity .


#################################################################
#    Data properties
#################################################################

###  http://www.softlang.org/ontologies/tbox#critique
:critique rdf:type owl:DatatypeProperty ;
          rdfs:domain :IssueEntity ;
          rdfs:range rdf:langString .


###  http://www.softlang.org/ontologies/tbox#hasBibTeX
:hasBibTeX rdf:type owl:DatatypeProperty ;
           rdfs:domain :Entity ;
           rdfs:range xsd:string .


###  http://www.softlang.org/ontologies/tbox#suggestion
:suggestion rdf:type owl:DatatypeProperty ;
            rdfs:domain :IssueEntity ;
            rdfs:range rdf:langString .


#################################################################
#    Classes
#################################################################

###  http://www.softlang.org/ontologies/tbox#ArtifactEntity
:ArtifactEntity rdf:type owl:Class ;
                rdfs:subClassOf :Entity ;
                :metamodelingPolicy "All non-immediate subclasses must also be of this type."@en ;
                rdfs:comment "Ontological entity used to represent software artifacts, artifact families, and artifact-related instances"@en ;
                rdfs:label "Artifact entity"@en .


###  http://www.softlang.org/ontologies/tbox#Assertion
:Assertion rdf:type owl:Class ;
           rdfs:subClassOf :ConceptualEntity ;
           rdfs:comment "Reified assertion entity used for qualified statements in language-related modules"@en ;
           rdfs:label "Assertion"@en ;
           <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/Reification_(knowledge_representation)> .


###  http://www.softlang.org/ontologies/tbox#CompositeConcept
:CompositeConcept rdf:type owl:Class ;
                  rdfs:subClassOf :LanguageConcept .


###  http://www.softlang.org/ontologies/tbox#ConceptualEntity
:ConceptualEntity rdf:type owl:Class ;
                  rdfs:subClassOf :Entity ;
                  :metamodelingPolicy "All non-immediate subclasses must also be of this type."@en ;
                  rdfs:comment "Contextual concepts for other entity types (foundations, languages, tools, and artifacts)"@en ;
                  rdfs:label "Conceptual entity"@en .


###  http://www.softlang.org/ontologies/tbox#EngineeringActivity
:EngineeringActivity rdf:type owl:Class ;
                     rdfs:subClassOf :ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#Entity
:Entity rdf:type owl:Class ;
        rdfs:subClassOf [ rdf:type owl:Class ;
                          owl:unionOf ( [ rdf:type owl:Restriction ;
                                          owl:onProperty <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> ;
                                          owl:someValuesFrom <http://xmlns.com/foaf/0.1/Document>
                                        ]
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty <http://xmlns.com/foaf/0.1/page> ;
                                          owl:someValuesFrom <http://xmlns.com/foaf/0.1/Document>
                                        ]
                                      )
                        ] ;
        rdfs:comment "Top-level category for entities represented in this ontology. Entities should be linked to at least one descriptive document via foaf:isPrimaryTopicOf or foaf:page."@en ;
        rdfs:label "Entity"@en ;
        <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Knowledge_representation_and_reasoning> .


###  http://www.softlang.org/ontologies/tbox#FormalEntity
:FormalEntity rdf:type owl:Class ;
              rdfs:subClassOf :Entity ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasArea ;
                                owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass :SubjectArea
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasSpace ;
                                owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass :TechnologicalSpace
                              ] ;
              :metamodelingPolicy "All non-immediate subclasses must also be of this type."@en ;
              rdfs:comment "Ontological entity used to represent formal formalisms, theories, models of computation, and methodological approaches"@en ;
              rdfs:label "Formal entity"@en .


###  http://www.softlang.org/ontologies/tbox#ImplementationMechanismConcept
:ImplementationMechanismConcept rdf:type owl:Class ;
                                rdfs:subClassOf :LanguageConcept .


###  http://www.softlang.org/ontologies/tbox#IssueEntity
:IssueEntity rdf:type owl:Class ;
             rdfs:subClassOf :Entity ;
             rdfs:comment "Entity for representing review issues, critiques, and proposed resolutions concerning resources, predicates, or fully specified assertions in the ontology"@en ;
             rdfs:label "Issue entity"@en ;
             <http://xmlns.com/foaf/0.1/page> <https://en.wikipedia.org/wiki/Issue_tracking_system> .


###  http://www.softlang.org/ontologies/tbox#LanguageConcept
:LanguageConcept rdf:type owl:Class ;
                 rdfs:subClassOf :ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#LanguageConceptApplicability
:LanguageConceptApplicability rdf:type owl:Class ;
                              rdfs:subClassOf :ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#LanguageEntity
:LanguageEntity rdf:type owl:Class ;
                rdfs:subClassOf :Entity ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :hasArea ;
                                  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                  owl:onClass :SubjectArea
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :hasSpace ;
                                  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                  owl:onClass :TechnologicalSpace
                                ] ;
                :metamodelingPolicy "All non-immediate subclasses must also be of this type."@en ;
                rdfs:comment "Ontological entity used to represent software languages, language families, and language-related instances"@en ;
                rdfs:label "Language entity"@en .


###  http://www.softlang.org/ontologies/tbox#LanguageSupportAssertion
:LanguageSupportAssertion rdf:type owl:Class ;
                          rdfs:subClassOf :Assertion .


###  http://www.softlang.org/ontologies/tbox#LanguageSupportKind
:LanguageSupportKind rdf:type owl:Class ;
                     rdfs:subClassOf :ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#MethodologicalApproach
:MethodologicalApproach rdf:type owl:Class ;
                        rdfs:subClassOf :FormalEntity .


###  http://www.softlang.org/ontologies/tbox#PropertyEntity
:PropertyEntity rdf:type owl:Class ;
                rdfs:subClassOf :Entity ;
                rdfs:comment "Ontological entity used to represent property declarations that participate in relations like other modeled entities"@en ;
                rdfs:label "Property entity"@en .


###  http://www.softlang.org/ontologies/tbox#SoftwareArtifact
:SoftwareArtifact rdf:type owl:Class ;
                  rdfs:subClassOf :ArtifactEntity .


###  http://www.softlang.org/ontologies/tbox#SoftwareLanguage
:SoftwareLanguage rdf:type owl:Class ;
                  rdfs:subClassOf :LanguageEntity .


###  http://www.softlang.org/ontologies/tbox#SoftwareTool
:SoftwareTool rdf:type owl:Class ;
              rdfs:subClassOf :ToolEntity .


###  http://www.softlang.org/ontologies/tbox#SubjectArea
:SubjectArea rdf:type owl:Class ;
             rdfs:subClassOf :ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#TechnologicalSpace
:TechnologicalSpace rdf:type owl:Class ;
                    rdfs:subClassOf :ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#ToolEntity
:ToolEntity rdf:type owl:Class ;
            rdfs:subClassOf :Entity ;
            :metamodelingPolicy "All non-immediate subclasses must also be of this type."@en ;
            rdfs:comment "Ontological entity used to represent software tools, tool families, and tool-related instances"@en ;
            rdfs:label "Tool entity"@en .


###  http://xmlns.com/foaf/0.1/Document
<http://xmlns.com/foaf/0.1/Document> rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://www.softlang.org/ontologies/tbox#CompositeConcept
:CompositeConcept rdf:type owl:NamedIndividual ,
                           :ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#EngineeringActivity
:EngineeringActivity rdf:type owl:NamedIndividual ,
                              :ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#ImplementationMechanismConcept
:ImplementationMechanismConcept rdf:type owl:NamedIndividual ,
                                         :ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#LanguageConcept
:LanguageConcept rdf:type owl:NamedIndividual ,
                          :ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#LanguageConceptApplicability
:LanguageConceptApplicability rdf:type owl:NamedIndividual ,
                                       :ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#LanguageSupportAssertion
:LanguageSupportAssertion rdf:type owl:NamedIndividual ,
                                   :ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#LanguageSupportKind
:LanguageSupportKind rdf:type owl:NamedIndividual ,
                              :ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#MethodologicalApproach
:MethodologicalApproach rdf:type owl:NamedIndividual ,
                                 :FormalEntity .


###  http://www.softlang.org/ontologies/tbox#SoftwareArtifact
:SoftwareArtifact rdf:type owl:NamedIndividual ,
                           :ArtifactEntity .


###  http://www.softlang.org/ontologies/tbox#SoftwareLanguage
:SoftwareLanguage rdf:type owl:NamedIndividual ,
                           :LanguageEntity .


###  http://www.softlang.org/ontologies/tbox#SoftwareTool
:SoftwareTool rdf:type owl:NamedIndividual ,
                       :ToolEntity .


###  http://www.softlang.org/ontologies/tbox#SubjectArea
:SubjectArea rdf:type owl:NamedIndividual ,
                      :ConceptualEntity .


###  http://www.softlang.org/ontologies/tbox#TechnologicalSpace
:TechnologicalSpace rdf:type owl:NamedIndividual ,
                             :ConceptualEntity ;
                    :hasBibTeX "KurtevBezivinAksit2002TechnologicalSpaces" .


###  http://www.softlang.org/ontologies/tbox#assertedForConcept
:assertedForConcept rdf:type owl:NamedIndividual ,
                             :PropertyEntity .


###  http://www.softlang.org/ontologies/tbox#assertedForLanguage
:assertedForLanguage rdf:type owl:NamedIndividual ,
                              :PropertyEntity .


###  http://www.softlang.org/ontologies/tbox#classifies
:classifies rdf:type owl:NamedIndividual ,
                     :PropertyEntity .


###  http://www.softlang.org/ontologies/tbox#commentingPolicy
:commentingPolicy rdf:type owl:NamedIndividual ,
                           :PropertyEntity .


###  http://www.softlang.org/ontologies/tbox#conformsTo
:conformsTo rdf:type owl:NamedIndividual ,
                     :PropertyEntity ;
