    <rdf:Description rdf:about="http://www.softlang.org/ontologies/ae#APIDescriptionArtifact">
        <tbox:elementOf rdf:resource="http://www.softlang.org/ontologies/le#InterfaceDescriptionLanguage"/>
        <rdfs:label xml:lang="en">API description artifact</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/ae#BuildScriptArtifact">
        <tbox:elementOf rdf:resource="http://www.softlang.org/ontologies/le#BuildScriptingLanguage"/>
        <rdfs:comment xml:lang="en">artifact kind for build scripts and build automation specifications</rdfs:comment>
        <rdfs:label xml:lang="en">Build script artifact</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Build_automation"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/ae#ConfigurationArtifact">
        <tbox:elementOf rdf:resource="http://www.softlang.org/ontologies/le#ConfigurationLanguage"/>
        <rdfs:comment xml:lang="en">artifact kind for configuration files and related configuration-level assets</rdfs:comment>
        <rdfs:label xml:lang="en">Configuration artifact</rdfs:label>
        <foaf:page rdf:resource="https://en.wikipedia.org/wiki/Configuration_file"/>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/ae#GrammarArtifact">
        <tbox:conformsTo rdf:resource="http://www.softlang.org/ontologies/ae#GrammarOfGrammarsArtifact"/>
        <tbox:elementOf rdf:resource="http://www.softlang.org/ontologies/le#GrammarMetalanguage"/>
        <rdfs:label xml:lang="en">Grammar artifact</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/ae#GrammarOfGrammarsArtifact">
        <tbox:defines rdf:resource="http://www.softlang.org/ontologies/le#GrammarMetalanguage"/>
        <tbox:elementOf rdf:resource="http://www.softlang.org/ontologies/le#GrammarMetalanguage"/>
        <rdfs:label xml:lang="en">Grammar of grammars artifact</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/ae#GraphQueryArtifact">
        <tbox:elementOf rdf:resource="http://www.softlang.org/ontologies/le#GraphQueryLanguage"/>
        <rdfs:label xml:lang="en">Graph query artifact</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/ae#JSONDocumentArtifact">
        <tbox:conformsTo rdf:resource="http://www.softlang.org/ontologies/ae#JSONSchemaArtifact"/>
        <tbox:elementOf rdf:resource="http://www.softlang.org/ontologies/le#JSON"/>
        <rdfs:label xml:lang="en">JSON document artifact</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/ae#JSONSchemaArtifact">
        <tbox:classifies rdf:resource="http://www.softlang.org/ontologies/ae#JSONDocumentArtifact"/>
        <tbox:elementOf rdf:resource="http://www.softlang.org/ontologies/le#JSONSchemaLanguage"/>
        <rdfs:label xml:lang="en">JSON schema artifact</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/ae#LogicProgramArtifact">
        <tbox:elementOf rdf:resource="http://www.softlang.org/ontologies/pe#ProgrammingLanguage"/>
        <rdfs:comment xml:lang="en">artifact kind typically associated with logic-paradigm programming languages such as Prolog and Datalog</rdfs:comment>
        <rdfs:label xml:lang="en">Logic-program artifact</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/ae#MarkupArtifact">
        <tbox:elementOf rdf:resource="http://www.softlang.org/ontologies/le#MarkupLanguage"/>
        <rdfs:label xml:lang="en">Markup artifact</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.softlang.org/ontologies/ae#MegamodelArtifact">
