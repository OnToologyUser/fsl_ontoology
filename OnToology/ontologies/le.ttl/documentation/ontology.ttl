@prefix : <http://www.softlang.org/ontologies/le#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.softlang.org/ontologies/le#> .

<http://www.softlang.org/ontologies/le> rdf:type owl:Ontology ;
                                         owl:imports <http://www.softlang.org/ontologies/tbox> ;
                                         <http://www.softlang.org/ontologies/tbox#commentingPolicy> "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         <http://www.softlang.org/ontologies/tbox#formattingPolicy> "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         <http://www.softlang.org/ontologies/tbox#linkingPolicy> "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         <http://www.softlang.org/ontologies/tbox#metamodelingPolicy> "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         rdfs:comment "Programming languages are maintained in the pe module; this module keeps non-programming software languages and broad language-kind taxonomies."@en ,
                                                      "Sub-ontology / ABox for software languages"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://www.softlang.org/ontologies/tbox#commentingPolicy
<http://www.softlang.org/ontologies/tbox#commentingPolicy> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#extends
<http://www.softlang.org/ontologies/tbox#extends> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#formattingPolicy
<http://www.softlang.org/ontologies/tbox#formattingPolicy> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#hasArea
<http://www.softlang.org/ontologies/tbox#hasArea> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#hasPart
<http://www.softlang.org/ontologies/tbox#hasPart> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#hasSpace
<http://www.softlang.org/ontologies/tbox#hasSpace> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#isPartOf
<http://www.softlang.org/ontologies/tbox#isPartOf> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#linkingPolicy
<http://www.softlang.org/ontologies/tbox#linkingPolicy> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#metamodelingPolicy
<http://www.softlang.org/ontologies/tbox#metamodelingPolicy> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#serves
<http://www.softlang.org/ontologies/tbox#serves> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#supports
<http://www.softlang.org/ontologies/tbox#supports> rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/isPrimaryTopicOf
<http://xmlns.com/foaf/0.1/isPrimaryTopicOf> rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/page
<http://xmlns.com/foaf/0.1/page> rdf:type owl:AnnotationProperty .


#################################################################
#    Classes
#################################################################

###  http://www.softlang.org/ontologies/le#BuildScriptingLanguage
:BuildScriptingLanguage rdf:type owl:Class ;
                        rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareLanguage> ;
                        owl:disjointWith [ rdf:type owl:Class ;
                                           owl:unionOf ( :ConstraintLanguage
                                                         :DataDefinitionLanguage
                                                         :DataManipulationLanguage
                                                         :QueryLanguage
                                                         :TransformationLanguage
                                                       )
                                         ] .


###  http://www.softlang.org/ontologies/le#ConfigurationLanguage
:ConfigurationLanguage rdf:type owl:Class ;
                       rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareLanguage> ;
                       owl:disjointWith [ rdf:type owl:Class ;
                                          owl:unionOf ( :ConstraintLanguage
                                                        :DataDefinitionLanguage
                                                        :DataManipulationLanguage
                                                        :QueryLanguage
                                                        :TransformationLanguage
                                                      )
                                        ] .


###  http://www.softlang.org/ontologies/le#ConstraintLanguage
:ConstraintLanguage rdf:type owl:Class ;
                    rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareLanguage> .


###  http://www.softlang.org/ontologies/le#DataDefinitionLanguage
:DataDefinitionLanguage rdf:type owl:Class ;
                        rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareLanguage> .


###  http://www.softlang.org/ontologies/le#DataManipulationLanguage
:DataManipulationLanguage rdf:type owl:Class ;
                          rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareLanguage> .


###  http://www.softlang.org/ontologies/le#DocumentTransformationLanguage
:DocumentTransformationLanguage rdf:type owl:Class ;
                                rdfs:subClassOf :TransformationLanguage .


###  http://www.softlang.org/ontologies/le#GrammarMetalanguage
:GrammarMetalanguage rdf:type owl:Class ;
                     rdfs:subClassOf :Metalanguage .


###  http://www.softlang.org/ontologies/le#GrammarTransformationLanguage
:GrammarTransformationLanguage rdf:type owl:Class ;
                               rdfs:subClassOf :TransformationLanguage .


###  http://www.softlang.org/ontologies/le#GraphQueryLanguage
:GraphQueryLanguage rdf:type owl:Class ;
                    rdfs:subClassOf :QueryLanguage .


###  http://www.softlang.org/ontologies/le#InterfaceDescriptionLanguage
:InterfaceDescriptionLanguage rdf:type owl:Class ;
                              rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareLanguage> ;
                              owl:disjointWith [ rdf:type owl:Class ;
                                                 owl:unionOf ( :ConstraintLanguage
                                                               :DataDefinitionLanguage
                                                               :DataManipulationLanguage
                                                               :QueryLanguage
                                                               :TransformationLanguage
                                                             )
                                               ] .


###  http://www.softlang.org/ontologies/le#JSONQueryLanguage
:JSONQueryLanguage rdf:type owl:Class ;
                   rdfs:subClassOf :QueryLanguage .


###  http://www.softlang.org/ontologies/le#JSONSchemaLanguage
:JSONSchemaLanguage rdf:type owl:Class ;
                    rdfs:subClassOf :SchemaLanguage .


###  http://www.softlang.org/ontologies/le#MappingLanguage
:MappingLanguage rdf:type owl:Class ;
                 rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareLanguage> ;
                 owl:disjointWith [ rdf:type owl:Class ;
                                    owl:unionOf ( :ConstraintLanguage
                                                  :DataDefinitionLanguage
                                                  :DataManipulationLanguage
                                                  :QueryLanguage
                                                  :TransformationLanguage
                                                )
                                  ] .


###  http://www.softlang.org/ontologies/le#MarkupLanguage
:MarkupLanguage rdf:type owl:Class ;
                rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareLanguage> ;
                owl:disjointWith [ rdf:type owl:Class ;
                                   owl:unionOf ( :ConstraintLanguage
                                                 :DataDefinitionLanguage
                                                 :DataManipulationLanguage
                                                 :QueryLanguage
                                                 :TransformationLanguage
                                               )
                                 ] .


###  http://www.softlang.org/ontologies/le#MegamodelingLanguage
:MegamodelingLanguage rdf:type owl:Class ;
                      rdfs:subClassOf :ModelingLanguage .


###  http://www.softlang.org/ontologies/le#Metalanguage
:Metalanguage rdf:type owl:Class ;
              rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareLanguage> ;
              owl:disjointWith [ rdf:type owl:Class ;
                                 owl:unionOf ( :ConstraintLanguage
                                               :DataDefinitionLanguage
                                               :DataManipulationLanguage
                                               :QueryLanguage
                                               :TransformationLanguage
                                             )
                               ] .


###  http://www.softlang.org/ontologies/le#MetamodelingLanguage
:MetamodelingLanguage rdf:type owl:Class ;
                      rdfs:subClassOf :Metalanguage .


###  http://www.softlang.org/ontologies/le#ModelTransformationLanguage
:ModelTransformationLanguage rdf:type owl:Class ;
                             rdfs:subClassOf :TransformationLanguage .


###  http://www.softlang.org/ontologies/le#ModelingLanguage
:ModelingLanguage rdf:type owl:Class ;
                  rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareLanguage> ;
                  owl:disjointWith [ rdf:type owl:Class ;
                                     owl:unionOf ( :ConstraintLanguage
                                                   :DataDefinitionLanguage
                                                   :DataManipulationLanguage
                                                   :QueryLanguage
                                                   :TransformationLanguage
                                                 )
                                   ] .


###  http://www.softlang.org/ontologies/le#OntologyLanguage
:OntologyLanguage rdf:type owl:Class ;
                  rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareLanguage> ;
                  owl:disjointWith [ rdf:type owl:Class ;
                                     owl:unionOf ( :ConstraintLanguage
                                                   :DataDefinitionLanguage
                                                   :DataManipulationLanguage
                                                   :QueryLanguage
                                                   :TransformationLanguage
                                                 )
                                   ] .


###  http://www.softlang.org/ontologies/le#ProofLanguage
:ProofLanguage rdf:type owl:Class ;
               rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareLanguage> ;
               owl:disjointWith [ rdf:type owl:Class ;
                                  owl:unionOf ( :ConstraintLanguage
                                                :DataDefinitionLanguage
                                                :DataManipulationLanguage
                                                :QueryLanguage
                                                :TransformationLanguage
                                              )
                                ] .


###  http://www.softlang.org/ontologies/le#PropertyGraphDataModelLanguage
:PropertyGraphDataModelLanguage rdf:type owl:Class ;
                                rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareLanguage> .


###  http://www.softlang.org/ontologies/le#QueryLanguage
:QueryLanguage rdf:type owl:Class ;
               rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareLanguage> .


###  http://www.softlang.org/ontologies/le#RelationalQueryLanguage
:RelationalQueryLanguage rdf:type owl:Class ;
                         rdfs:subClassOf :QueryLanguage .


###  http://www.softlang.org/ontologies/le#RequirementsSpecificationLanguage
:RequirementsSpecificationLanguage rdf:type owl:Class ;
                                   rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareLanguage> ;
                                   owl:disjointWith [ rdf:type owl:Class ;
                                                      owl:unionOf ( :ConstraintLanguage
                                                                    :DataDefinitionLanguage
                                                                    :DataManipulationLanguage
                                                                    :QueryLanguage
                                                                    :TransformationLanguage
                                                                  )
                                                    ] .


###  http://www.softlang.org/ontologies/le#RuleLanguage
:RuleLanguage rdf:type owl:Class ;
              rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareLanguage> ;
              owl:disjointWith [ rdf:type owl:Class ;
                                 owl:unionOf ( :ConstraintLanguage
                                               :DataDefinitionLanguage
                                               :DataManipulationLanguage
                                               :QueryLanguage
                                               :TransformationLanguage
                                             )
                               ] .


###  http://www.softlang.org/ontologies/le#SchemaLanguage
:SchemaLanguage rdf:type owl:Class ;
                rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareLanguage> ;
                owl:disjointWith [ rdf:type owl:Class ;
                                   owl:unionOf ( :ConstraintLanguage
                                                 :DataDefinitionLanguage
                                                 :DataManipulationLanguage
                                                 :QueryLanguage
                                                 :TransformationLanguage
                                               )
                                 ] .


###  http://www.softlang.org/ontologies/le#SemanticDataModelLanguage
:SemanticDataModelLanguage rdf:type owl:Class ;
                           rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareLanguage> ;
                           owl:disjointWith [ rdf:type owl:Class ;
                                              owl:unionOf ( :ConstraintLanguage
                                                            :DataDefinitionLanguage
                                                            :DataManipulationLanguage
                                                            :QueryLanguage
                                                            :TransformationLanguage
                                                          )
                                            ] .


###  http://www.softlang.org/ontologies/le#SemanticQueryLanguage
:SemanticQueryLanguage rdf:type owl:Class ;
                       rdfs:subClassOf :QueryLanguage .


###  http://www.softlang.org/ontologies/le#TransformationLanguage
:TransformationLanguage rdf:type owl:Class ;
                        rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareLanguage> .


###  http://www.softlang.org/ontologies/le#XMLQueryLanguage
:XMLQueryLanguage rdf:type owl:Class ;
                  rdfs:subClassOf :QueryLanguage .


###  http://www.softlang.org/ontologies/le#XMLSchemaLanguage
:XMLSchemaLanguage rdf:type owl:Class ;
                   rdfs:subClassOf :SchemaLanguage .


###  http://www.softlang.org/ontologies/pe#ProgrammingLanguage
<http://www.softlang.org/ontologies/pe#ProgrammingLanguage> rdf:type owl:Class ;
                                                            owl:disjointWith [ rdf:type owl:Class ;
                                                                               owl:unionOf ( :ConstraintLanguage
                                                                                             :DataDefinitionLanguage
                                                                                             :DataManipulationLanguage
                                                                                             :QueryLanguage
                                                                                             :TransformationLanguage
                                                                                           )
                                                                             ] .


###  http://www.softlang.org/ontologies/tbox#LanguageEntity
<http://www.softlang.org/ontologies/tbox#LanguageEntity> rdf:type owl:Class .


###  http://www.softlang.org/ontologies/tbox#SoftwareLanguage
<http://www.softlang.org/ontologies/tbox#SoftwareLanguage> rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://www.softlang.org/ontologies/le#ATL
:ATL rdf:type owl:NamedIndividual ,
              :ModelTransformationLanguage ,
              <http://www.softlang.org/ontologies/tbox#LanguageEntity> ;
     <http://www.softlang.org/ontologies/tbox#hasArea> <http://www.softlang.org/ontologies/ce#MDE> ,
                                                       <http://www.softlang.org/ontologies/ce#SE> ,
                                                       <http://www.softlang.org/ontologies/ce#SLE> ;
     <http://www.softlang.org/ontologies/tbox#hasSpace> <http://www.softlang.org/ontologies/ce#Modelware> ;
     <http://www.softlang.org/ontologies/tbox#supports> <http://www.softlang.org/ontologies/ce#Abstraction> ,
                                                        <http://www.softlang.org/ontologies/ce#DataAbstraction> ,
                                                        <http://www.softlang.org/ontologies/ce#ModelingConcept> ,
                                                        <http://www.softlang.org/ontologies/ce#TransformationConcept> ;
     rdfs:label "ATL"@en ;
     <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/ATLAS_Transformation_Language> .


###  http://www.softlang.org/ontologies/le#BNF
:BNF rdf:type owl:NamedIndividual ,
              :GrammarMetalanguage ,
              <http://www.softlang.org/ontologies/tbox#LanguageEntity> ;
     <http://www.softlang.org/ontologies/tbox#hasArea> <http://www.softlang.org/ontologies/ce#CC> ,
                                                       <http://www.softlang.org/ontologies/ce#SLE> ,
                                                       <http://www.softlang.org/ontologies/ce#TCS> ;
     <http://www.softlang.org/ontologies/tbox#hasSpace> <http://www.softlang.org/ontologies/ce#Grammarware> ;
     <http://www.softlang.org/ontologies/tbox#supports> <http://www.softlang.org/ontologies/ce#GrammarConcept> ,
                                                        <http://www.softlang.org/ontologies/ce#Recursion> ;
     rdfs:comment "grammar metalanguage for expressing context-free grammars"@en ;
     rdfs:label "BNF"@en ;
     <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/Backus%E2%80%93Naur_form> .


###  http://www.softlang.org/ontologies/le#BackusNaurForm
:BackusNaurForm rdf:type owl:NamedIndividual ,
                         :GrammarMetalanguage ,
                         <http://www.softlang.org/ontologies/tbox#LanguageEntity> ;
                <http://www.softlang.org/ontologies/tbox#hasArea> <http://www.softlang.org/ontologies/ce#CC> ,
                                                                  <http://www.softlang.org/ontologies/ce#SLE> ;
                <http://www.softlang.org/ontologies/tbox#hasSpace> <http://www.softlang.org/ontologies/ce#Grammarware> ;
                <http://www.softlang.org/ontologies/tbox#serves> <http://www.softlang.org/ontologies/fe#ConcreteSyntaxDefinitionApproach> ;
                <http://www.softlang.org/ontologies/tbox#supports> <http://www.softlang.org/ontologies/ce#GrammarConcept> ,
                                                                   <http://www.softlang.org/ontologies/ce#Recursion> ;
                rdfs:comment "metalanguage for expressing context-free grammars"@en ;
                rdfs:label "Backus-Naur form"@en ;
                <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/Backus%E2%80%93Naur_form> .


