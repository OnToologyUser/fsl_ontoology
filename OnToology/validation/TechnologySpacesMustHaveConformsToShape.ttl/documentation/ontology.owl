<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.w3.org/2002/07/owl#"
     xml:base="http://www.w3.org/2002/07/owl"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:shacl="http://www.w3.org/ns/shacl#">
    <Ontology/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/ns/shacl#message -->


    <AnnotationProperty rdf:about="http://www.w3.org/ns/shacl#message"/>
    


    <!-- http://www.w3.org/ns/shacl#select -->


    <AnnotationProperty rdf:about="http://www.w3.org/ns/shacl#select"/>
    


    <!-- http://www.w3.org/ns/shacl#sparql -->


    <AnnotationProperty rdf:about="http://www.w3.org/ns/shacl#sparql"/>
    


    <!-- http://www.w3.org/ns/shacl#targetClass -->


    <AnnotationProperty rdf:about="http://www.w3.org/ns/shacl#targetClass"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/ns/shacl#NodeShape -->


    <Class rdf:about="http://www.w3.org/ns/shacl#NodeShape"/>
    


    <!-- http://www.w3.org/ns/shacl#SPARQLConstraint -->


    <Class rdf:about="http://www.w3.org/ns/shacl#SPARQLConstraint"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.softlang.org/ontologies/ve#TechnologySpacesMustHaveConformsToShape -->


    <NamedIndividual rdf:about="http://www.softlang.org/ontologies/ve#TechnologySpacesMustHaveConformsToShape">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#NodeShape"/>
        <rdfs:comment>TODO</rdfs:comment>
        <shacl:sparql rdf:nodeID="genid2"/>
        <shacl:targetClass rdf:resource="http://www.softlang.org/ontologies/ce#TechnologicalSpace"/>
    </NamedIndividual>
    <rdf:Description rdf:nodeID="genid2">
        <rdf:type rdf:resource="http://www.w3.org/ns/shacl#SPARQLConstraint"/>
        <shacl:message>Each technological space must be associated with two (not necessarily distinct) language entities l1, l2 and two distinct artifact entities a1, a2 such that l1 hasSpace s, l2 hasSpace s, a1 elementOf l1, a2 elementOf l2, and a1 conformsTo a2.</shacl:message>
        <shacl:select>
      PREFIX tbox: &lt;http://www.softlang.org/ontologies/tbox#&gt;
      PREFIX ae:   &lt;http://www.softlang.org/ontologies/ae#&gt;
      PREFIX ce:   &lt;http://www.softlang.org/ontologies/ce#&gt;
      PREFIX rdf:  &lt;http://www.w3.org/1999/02/22-rdf-syntax-ns#&gt;

      SELECT $this
      WHERE {
        FILTER($this NOT IN (
            ce:APIware,
            ce:Graphware,
            ce:Logicware,
            ce:Markupware,
            ce:Programware,
            ce:Proofware,
            ce:Ruleware
          )
        )
        FILTER NOT EXISTS {
          ?l1 tbox:hasSpace $this .
          ?l2 tbox:hasSpace $this .

          ?l1 rdf:type tbox:LanguageEntity .
          ?l2 rdf:type tbox:LanguageEntity .

          ?a1 tbox:elementOf ?l1 .
          ?a2 tbox:elementOf ?l2 .
          FILTER(?a1 != ?a2)

          ?a1 rdf:type tbox:ArtifactEntity .
          ?a2 rdf:type tbox:ArtifactEntity .

          ?a1 tbox:conformsTo ?a2 .
        }
      }
    </shacl:select>
    </rdf:Description>
</rdf:RDF>



