        <rdfs:label xml:lang="en">Constraint satisfaction problem</rdfs:label>
        <foaf:isPrimaryTopicOf rdf:resource="https://en.wikipedia.org/wiki/Constraint_satisfaction_problem"/>
    </owl:NamedIndividual>
    


