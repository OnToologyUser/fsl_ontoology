@prefix : <http://www.softlang.org/ontologies/te#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.softlang.org/ontologies/te#> .

<http://www.softlang.org/ontologies/te> rdf:type owl:Ontology ;
                                         owl:imports <http://www.softlang.org/ontologies/tbox> ;
                                         <http://www.softlang.org/ontologies/tbox#commentingPolicy> "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         <http://www.softlang.org/ontologies/tbox#formattingPolicy> "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         <http://www.softlang.org/ontologies/tbox#linkingPolicy> "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         <http://www.softlang.org/ontologies/tbox#metamodelingPolicy> "See http://www.softlang.org/ontologies/tbox -- the same policy applies here."@en ;
                                         rdfs:comment "Sub-ontology / ABox for software tools"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://www.softlang.org/ontologies/tbox#commentingPolicy
<http://www.softlang.org/ontologies/tbox#commentingPolicy> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#formattingPolicy
<http://www.softlang.org/ontologies/tbox#formattingPolicy> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#hasAffectedArtifact
<http://www.softlang.org/ontologies/tbox#hasAffectedArtifact> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#hasInputArtifact
<http://www.softlang.org/ontologies/tbox#hasInputArtifact> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#hasOutputArtifact
<http://www.softlang.org/ontologies/tbox#hasOutputArtifact> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#hasSpace
<http://www.softlang.org/ontologies/tbox#hasSpace> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#linkingPolicy
<http://www.softlang.org/ontologies/tbox#linkingPolicy> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#metamodelingPolicy
<http://www.softlang.org/ontologies/tbox#metamodelingPolicy> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#processes
<http://www.softlang.org/ontologies/tbox#processes> rdf:type owl:AnnotationProperty .


###  http://www.softlang.org/ontologies/tbox#targets
<http://www.softlang.org/ontologies/tbox#targets> rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/isPrimaryTopicOf
<http://xmlns.com/foaf/0.1/isPrimaryTopicOf> rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/page
<http://xmlns.com/foaf/0.1/page> rdf:type owl:AnnotationProperty .


#################################################################
#    Classes
#################################################################

###  http://www.softlang.org/ontologies/tbox#SoftwareTool
<http://www.softlang.org/ontologies/tbox#SoftwareTool> rdf:type owl:Class .


###  http://www.softlang.org/ontologies/tbox#ToolEntity
<http://www.softlang.org/ontologies/tbox#ToolEntity> rdf:type owl:Class .


###  http://www.softlang.org/ontologies/te#APIWorkbench
:APIWorkbench rdf:type owl:Class ;
              rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareTool> .


###  http://www.softlang.org/ontologies/te#BuildTool
:BuildTool rdf:type owl:Class ;
           rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareTool> .


###  http://www.softlang.org/ontologies/te#Compiler
:Compiler rdf:type owl:Class ;
          rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareTool> .


###  http://www.softlang.org/ontologies/te#ConfigurationTool
:ConfigurationTool rdf:type owl:Class ;
                   rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareTool> .


###  http://www.softlang.org/ontologies/te#Database
:Database rdf:type owl:Class ;
          rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareTool> .


###  http://www.softlang.org/ontologies/te#GrammarAnalyzer
:GrammarAnalyzer rdf:type owl:Class ;
                 rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareTool> .


###  http://www.softlang.org/ontologies/te#GrammarTransformationEngine
:GrammarTransformationEngine rdf:type owl:Class ;
                             rdfs:subClassOf :TransformationEngine .


###  http://www.softlang.org/ontologies/te#GraphDatabase
:GraphDatabase rdf:type owl:Class ;
               rdfs:subClassOf :Database .


###  http://www.softlang.org/ontologies/te#GraphDatabaseManagementSystem
:GraphDatabaseManagementSystem rdf:type owl:Class ;
                               rdfs:subClassOf :GraphDatabase ,
                                               :QueryProcessor .


###  http://www.softlang.org/ontologies/te#Interpreter
:Interpreter rdf:type owl:Class ;
             rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareTool> .


###  http://www.softlang.org/ontologies/te#JSONProcessor
:JSONProcessor rdf:type owl:Class ;
               rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareTool> ;
               owl:disjointWith :XMLProcessor .


###  http://www.softlang.org/ontologies/te#LogicProgrammingSystem
:LogicProgrammingSystem rdf:type owl:Class ;
                        rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareTool> .


###  http://www.softlang.org/ontologies/te#MarkupProcessor
:MarkupProcessor rdf:type owl:Class ;
                 rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareTool> .


###  http://www.softlang.org/ontologies/te#ModelTransformationEngine
:ModelTransformationEngine rdf:type owl:Class ;
                           rdfs:subClassOf :TransformationEngine .


###  http://www.softlang.org/ontologies/te#ModelValidator
:ModelValidator rdf:type owl:Class ;
                rdfs:subClassOf :Validator .


###  http://www.softlang.org/ontologies/te#ModelingWorkbench
:ModelingWorkbench rdf:type owl:Class ;
                   rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareTool> .


###  http://www.softlang.org/ontologies/te#OntologyEditor
:OntologyEditor rdf:type owl:Class ;
                rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareTool> .


###  http://www.softlang.org/ontologies/te#ParserGenerator
:ParserGenerator rdf:type owl:Class ;
                 rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareTool> .


###  http://www.softlang.org/ontologies/te#ProofAssistant
:ProofAssistant rdf:type owl:Class ;
                rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareTool> .


###  http://www.softlang.org/ontologies/te#QueryProcessor
:QueryProcessor rdf:type owl:Class ;
                rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareTool> .


###  http://www.softlang.org/ontologies/te#Reasoner
:Reasoner rdf:type owl:Class ;
          rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareTool> ,
                          :SemanticReasoner .


###  http://www.softlang.org/ontologies/te#RefactoringTool
:RefactoringTool rdf:type owl:Class ;
                 rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareTool> .


###  http://www.softlang.org/ontologies/te#RelationalDatabaseManagementSystem
:RelationalDatabaseManagementSystem rdf:type owl:Class ;
                                    rdfs:subClassOf :QueryProcessor ,
                                                    :Validator .


###  http://www.softlang.org/ontologies/te#RequirementsTool
:RequirementsTool rdf:type owl:Class ;
                  rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareTool> .


###  http://www.softlang.org/ontologies/te#RuleEngine
:RuleEngine rdf:type owl:Class ;
            rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareTool> .


###  http://www.softlang.org/ontologies/te#SemanticReasoner
:SemanticReasoner rdf:type owl:Class ;
                  rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareTool> .


###  http://www.softlang.org/ontologies/te#StaticAnalyzer
:StaticAnalyzer rdf:type owl:Class ;
                rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareTool> .


###  http://www.softlang.org/ontologies/te#TransformationEngine
:TransformationEngine rdf:type owl:Class ;
                      rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareTool> .


###  http://www.softlang.org/ontologies/te#TripleStore
:TripleStore rdf:type owl:Class ;
             rdfs:subClassOf :QueryProcessor .


###  http://www.softlang.org/ontologies/te#Validator
:Validator rdf:type owl:Class ;
           rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareTool> .


###  http://www.softlang.org/ontologies/te#XMLProcessor
:XMLProcessor rdf:type owl:Class ;
              rdfs:subClassOf <http://www.softlang.org/ontologies/tbox#SoftwareTool> .


#################################################################
#    Individuals
#################################################################

###  http://www.softlang.org/ontologies/te#ANTLR
:ANTLR rdf:type owl:NamedIndividual ,
                <http://www.softlang.org/ontologies/tbox#ToolEntity> ,
                :ParserGenerator ;
       rdfs:comment "parser generator based on grammar notation with semantic and syntactic processing support"@en ;
       rdfs:label "ANTLR"@en ;
       <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/ANTLR> .


###  http://www.softlang.org/ontologies/te#APIWorkbench
:APIWorkbench rdf:type owl:NamedIndividual ,
                       <http://www.softlang.org/ontologies/tbox#ToolEntity> .


###  http://www.softlang.org/ontologies/te#ATLTransformationEngine
:ATLTransformationEngine rdf:type owl:NamedIndividual ,
                                  <http://www.softlang.org/ontologies/tbox#ToolEntity> ,
                                  :ModelTransformationEngine ;
                         rdfs:comment "engine for executing ATL model transformations"@en ;
                         rdfs:label "ATL transformation engine"@en ;
                         <http://xmlns.com/foaf/0.1/page> <https://eclipse.dev/atl/> .


###  http://www.softlang.org/ontologies/te#Ansible
:Ansible rdf:type owl:NamedIndividual ,
                  <http://www.softlang.org/ontologies/tbox#ToolEntity> ,
                  :ConfigurationTool ;
         rdfs:comment "configuration automation tool commonly used with YAML-based configuration artifacts"@en ;
         rdfs:label "Ansible"@en ;
         <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/Ansible_(software)> .


###  http://www.softlang.org/ontologies/te#ApacheJena
:ApacheJena rdf:type owl:NamedIndividual ,
                     <http://www.softlang.org/ontologies/tbox#ToolEntity> ,
                     :Reasoner ,
                     :TripleStore ;
            rdfs:comment "framework for RDF storage, SPARQL processing, and reasoning"@en ;
            rdfs:label "Apache Jena"@en ;
            <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> <https://en.wikipedia.org/wiki/Apache_Jena> .


###  http://www.softlang.org/ontologies/te#BaseX
:BaseX rdf:type owl:NamedIndividual ,
                <http://www.softlang.org/ontologies/tbox#ToolEntity> ,
