<http://www.w3.org/ns/shacl#SPARQLConstraint> rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://www.softlang.org/ontologies/ve#TechnologySpacesMustHaveConformsToShape
<http://www.softlang.org/ontologies/ve#TechnologySpacesMustHaveConformsToShape> rdf:type owl:NamedIndividual ,
                                                                                         <http://www.w3.org/ns/shacl#NodeShape> ;
                                                                                rdfs:comment "TODO" ;
                                                                                <http://www.w3.org/ns/shacl#sparql> _:genid2 ;
                                                                                <http://www.w3.org/ns/shacl#targetClass> <http://www.softlang.org/ontologies/ce#TechnologicalSpace> .

_:genid2 rdf:type <http://www.w3.org/ns/shacl#SPARQLConstraint> ;
          <http://www.w3.org/ns/shacl#message> "Each technological space must be associated with two (not necessarily distinct) language entities l1, l2 and two distinct artifact entities a1, a2 such that l1 hasSpace s, l2 hasSpace s, a1 elementOf l1, a2 elementOf l2, and a1 conformsTo a2." ;
          <http://www.w3.org/ns/shacl#select> """
      PREFIX tbox: <http://www.softlang.org/ontologies/tbox#>
      PREFIX ae:   <http://www.softlang.org/ontologies/ae#>
      PREFIX ce:   <http://www.softlang.org/ontologies/ce#>
      PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

      SELECT $this
      WHERE {
        FILTER($this NOT IN (
            ce:APIware,
            ce:Graphware,
            ce:Logicware,
            ce:Markupware,
            ce:Programware,
            ce:Proofware,
            ce:Ruleware
          )
        )
        FILTER NOT EXISTS {
          ?l1 tbox:hasSpace $this .
          ?l2 tbox:hasSpace $this .

          ?l1 rdf:type tbox:LanguageEntity .
          ?l2 rdf:type tbox:LanguageEntity .

          ?a1 tbox:elementOf ?l1 .
          ?a2 tbox:elementOf ?l2 .
          FILTER(?a1 != ?a2)

          ?a1 rdf:type tbox:ArtifactEntity .
          ?a2 rdf:type tbox:ArtifactEntity .

          ?a1 tbox:conformsTo ?a2 .
        }
      }
    """ .


